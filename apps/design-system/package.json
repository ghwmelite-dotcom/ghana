{
  "name": "@gh/design-system",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "design.gov.gh — Ghana Design System documentation site. Astro 5 static build for Cloudflare Pages.",
  "scripts": {
    "dev": "astro dev",
    "typecheck": "astro check",
    "lint": "eslint --ext .ts,.mjs,.astro src",
    "test": "node --experimental-strip-types scripts/axe-check.mjs",
    "prebuild": "node scripts/prebuild.mjs",
    "build": "pnpm run prebuild && astro build",
    "preview": "astro preview",
    "measure:weight": "node --experimental-strip-types scripts/measure-weight.mjs"
  },
  "dependencies": {
    "@gh/gh-ds": "workspace:*",
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "axe-core": "^4.10.2",
    "eslint-plugin-astro": "^1.3.1",
    "jsdom": "^25.0.1"
  }
}
