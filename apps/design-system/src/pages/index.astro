---
import BaseLayout from '../layouts/BaseLayout.astro';

const tiers = [
  {
    title: 'Tier 1 — Foundation',
    note: '13 components. Every form and page-chrome primitive.',
    items: [
      'Button',
      'TextInput',
      'Textarea',
      'RadioGroup',
      'CheckboxGroup',
      'Select',
      'DateInput',
      'ErrorSummary',
      'Form label/hint/error composite',
      'SkipLink',
      'BackLink',
      'Header',
      'Footer',
    ],
  },
  {
    title: 'Tier 2 — Content and navigation',
    note: '7 components. Everything a content-heavy page needs.',
    items: ['Breadcrumb', 'Card', 'NotificationBanner', 'Pagination', 'Accordion', 'Table', 'Tabs'],
  },
  {
    title: 'Tier 3 — Service flow',
    note: '6 components. Multi-step forms, submit, and portal chrome.',
    items: [
      'StepIndicator',
      'SummaryList',
      'ConfirmationPanel',
      'Search',
      'MostRequestedBand',
      'CookieBanner',
    ],
  },
];
---

<BaseLayout
  title="Ghana Design System"
  description="design.gov.gh — the Ghana Design System. Accessible, fast, open-source components for every .gov.gh property."
>
  <h1>Ghana Design System</h1>
  <p class="lede">
    The component library every <code>.gov.gh</code> property uses. Accessible by default, no JavaScript
    required, multilingual from day one. Fork it, extend it, ship it under MIT.
  </p>

  <h2 id="what">What this is</h2>
  <p>
    25 components plus tokens, fonts, and CI gates. Forked in intent from the GOV.UK Design System
    per <a
      href="https://github.com/ghwmelite-dotcom/gov-gh/blob/main/docs/adr/003-ghds-forks-govuk-frontend.md"
      >ADR-003</a
    >, rebranded for Ghana with flag colours, Noto Sans coverage for Twi and Ewe glyphs, and
    44-pixel touch targets on every interactive element.
  </p>

  <h2 id="start">Start here</h2>
  <ul class="next-steps">
    <li><a href="/components/">Browse every component</a></li>
    <li>
      <a href="https://github.com/ghwmelite-dotcom/gov-gh/tree/main/packages/gh-ds"
        >See the source on GitHub</a
      >
    </li>
    <li>
      <a href="https://github.com/ghwmelite-dotcom/gov-gh/blob/main/docs/adr/">Read the ADRs</a>
    </li>
  </ul>

  <h2 id="catalogue">Component catalogue</h2>
  <p>
    Every component, grouped by role. Deep links go to the single components page; anchor fragments
    scroll to each entry.
  </p>

  {
    tiers.map((tier) => (
      <section
        class="tier"
        aria-labelledby={`tier-${tier.title.replace(/\W+/g, '-').toLowerCase()}`}
      >
        <h3 id={`tier-${tier.title.replace(/\W+/g, '-').toLowerCase()}`} class="tier-heading">
          {tier.title}
          <span class="component-count">— {tier.items.length}</span>
        </h3>
        <p>{tier.note}</p>
        <ul class="tier-list">
          {tier.items.map((item) => {
            const slug = item.replace(/[^A-Za-z0-9]+/g, '-').toLowerCase();
            return (
              <li>
                <a href={`/components/#${slug}`}>{item}</a>
              </li>
            );
          })}
        </ul>
      </section>
    ))
  }

  <h2 id="principles">Operating principles</h2>
  <ul>
    <li>
      <strong>Accessible by default.</strong> WCAG 2.2 AA is the floor. Every component passes axe-core
      with zero blocking violations in CI. No ships without it.
    </li>
    <li>
      <strong>Progressive enhancement.</strong> Every form works without JavaScript. Islands enhance,
      never gate.
    </li>
    <li>
      <strong>Multilingual from day one.</strong> Noto Sans covers Akan, Ewe, Ga, Dagbani, Hausa glyphs.
      Every component has EN and Twi fixtures.
    </li>
    <li>
      <strong>Cultural respect, not wallpaper.</strong> Adinkra symbols map to specific uses per CLAUDE.md
      §6.3. Folklore-Board clearance lands before any symbol ships.
    </li>
    <li>
      <strong>Open by default.</strong> MIT code, OFL fonts, CC-BY content.
    </li>
  </ul>

  <h2 id="licence">Licence</h2>
  <p>
    MIT for the TypeScript and component source. SIL Open Font Licence 1.1 for the fonts (Noto Sans,
    Inter, JetBrains Mono). Content licensed CC BY 4.0. Upstream GOV.UK Frontend attribution is
    preserved in
    <a href="https://github.com/ghwmelite-dotcom/gov-gh/blob/main/packages/gh-ds/NOTICE"
      ><code>packages/gh-ds/NOTICE</code></a
    >.
  </p>
</BaseLayout>

<style>
  .lede {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    max-width: 56rem;
    margin-bottom: var(--space-8);
  }

  .next-steps {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-8);
    display: grid;
    gap: var(--space-2);
  }

  .next-steps li {
    border-left: 4px solid var(--color-action-primary);
    padding: var(--space-2) var(--space-4);
    background: var(--ghana-green-50);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .tier {
    margin-bottom: var(--space-8);
  }

  .tier-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: var(--space-2);
  }

  .tier-list li {
    padding: var(--space-2) 0;
    border-top: var(--border-width-hairline) solid var(--color-border-default);
  }

  .tier-list a {
    display: block;
    padding: var(--space-1) 0;
    font-weight: var(--font-weight-semibold);
  }
</style>
