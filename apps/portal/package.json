{
  "name": "@gh/portal",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "gov.gh root portal — Astro 5 static build for Cloudflare Pages.",
  "scripts": {
    "dev": "astro dev",
    "typecheck": "astro check",
    "lint": "eslint --ext .ts,.mjs,.astro src",
    "test": "node scripts/routes-test.mjs && node --experimental-strip-types scripts/axe-check.mjs",
    "prebuild": "node scripts/prebuild.mjs",
    "build": "pnpm run prebuild && astro build && pagefind --site dist",
    "preview": "astro preview",
    "measure:weight": "node --experimental-strip-types scripts/measure-weight.mjs"
  },
  "dependencies": {
    "@gh/gh-ds": "workspace:*",
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/node": "^22.9.0",
    "axe-core": "^4.10.2",
    "eslint-plugin-astro": "^1.3.1",
    "jsdom": "^25.0.1",
    "pagefind": "^1.5.2"
  }
}
