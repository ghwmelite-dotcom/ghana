---
/**
 * Latest updates — gov.rw's news list. A section heading, then a vertical
 * stack of news cards, each with an optional thumbnail, a category tag, a
 * headline, a short preview, and a publish date.
 */
import { Image } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';
import accraMarket from '../assets/photos/accra-market.png';
import nkrumahBlackStar from '../assets/photos/nkrumah-black-star.png';
import independenceArch from '../assets/photos/independence-arch.png';
import nkrumahMemorial from '../assets/photos/nkrumah-memorial.png';

const all: CollectionEntry<'news'>[] = (await getCollection('news')).sort(
  (a: CollectionEntry<'news'>, b: CollectionEntry<'news'>) =>
    b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);
const items = all.slice(0, 4);

// Rotate a small pool of placeholder thumbnails until each news entry has
// its own heroImage authored into the content collection.
const placeholders = [accraMarket, nkrumahBlackStar, independenceArch, nkrumahMemorial];

const formatter = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const ministryLabel = (slug: string) =>
  slug
    .split('-')
    .map((w) => (w.length > 3 ? w[0].toUpperCase() + w.slice(1) : w))
    .join(' ');
---

<section class="news" aria-labelledby="news-heading">
  <div class="news__inner">
    <header class="news__head" data-reveal>
      <div>
        <p class="news__eyebrow">
          <span class="eyebrow-star" aria-hidden="true"></span>
          Latest updates
        </p>
        <h2 id="news-heading" class="news__title">From across government.</h2>
      </div>
      <a href="/news/" class="news__more">
        View all news
        <svg viewBox="0 0 16 16" width="12" height="12" fill="none" aria-hidden="true">
          <path
            d="M3 8 h10 M9 4 l4 4 -4 4"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
    </header>

    {
      items.length === 0 ? (
        <p class="news__empty">News will appear here as it is published.</p>
      ) : (
        <ul class="news__list">
          {items.map((n, i) => (
            <li class="news-item" data-reveal data-reveal-delay={String(i + 1)}>
              <a
                href={`/news/${n.data.publishedAt.getFullYear()}/${n.slug}/`}
                class="news-item__link"
              >
                <figure class="news-item__thumb" aria-hidden="true">
                  <Image
                    src={placeholders[i % placeholders.length]}
                    alt=""
                    widths={[240, 360, 480]}
                    sizes="(min-width: 48rem) 220px, 100vw"
                    quality={72}
                  />
                </figure>
                <div class="news-item__body">
                  <p class="news-item__meta">
                    <span class="news-item__tag">{ministryLabel(n.data.ministry)}</span>
                    <time datetime={n.data.publishedAt.toISOString()}>
                      {formatter.format(n.data.publishedAt)}
                    </time>
                  </p>
                  <h3 class="news-item__title">{n.data.title}</h3>
                  <p class="news-item__lede">{n.data.lede}</p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</section>

<style>
  .news {
    background: #f7f7f5;
    padding: clamp(3rem, 6vw, 5rem) clamp(1.25rem, 4vw, 3rem);
    border-bottom: 1px solid #edeae2;
  }
  .news__inner {
    max-width: 80rem;
    margin: 0 auto;
  }
  .news__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: clamp(1.75rem, 3vw, 2.5rem);
  }
  .news__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: #005a35;
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .news__title {
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    font-weight: 700;
    color: #0a0f1f;
    margin: 0;
    letter-spacing: -0.015em;
  }
  .news__more {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #005a35;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
  }
  .news__more:hover,
  .news__more:focus-visible {
    border-bottom-color: #005a35;
  }

  .news__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .news-item__link {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    padding: 1rem;
    background: #fff;
    border: 1px solid #edeae2;
    border-radius: 4px;
    text-decoration: none;
    color: inherit;
    transition:
      transform 200ms cubic-bezier(0.2, 0.9, 0.3, 1),
      box-shadow 200ms ease,
      border-color 200ms ease;
  }
  @media (min-width: 48rem) {
    .news-item__link {
      grid-template-columns: 200px minmax(0, 1fr);
      align-items: start;
    }
  }
  .news-item__link:hover,
  .news-item__link:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px -14px rgba(0, 40, 24, 0.16);
    border-color: #005a35;
  }
  .news-item__link:focus-visible {
    outline: 3px solid #fcd116;
    outline-offset: 3px;
  }
  .news-item__thumb {
    margin: 0;
    aspect-ratio: 16 / 10;
    border-radius: 3px;
    overflow: hidden;
    background: #edeae2;
    position: relative;
  }
  .news-item__thumb :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 700ms cubic-bezier(0.2, 0.9, 0.3, 1);
  }
  .news-item__link:hover .news-item__thumb :global(img),
  .news-item__link:focus-visible .news-item__thumb :global(img) {
    transform: scale(1.06);
  }
  .news-item__body {
    padding: 0.25rem 0;
  }
  .news-item__meta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    margin: 0 0 0.5rem;
    flex-wrap: wrap;
  }
  .news-item__tag {
    background: #005a35;
    color: #fff;
    padding: 3px 8px;
    border-radius: 2px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-size: 0.6875rem;
    transition:
      background 220ms ease,
      box-shadow 220ms ease;
  }
  .news-item__link:hover .news-item__tag,
  .news-item__link:focus-visible .news-item__tag {
    background: #004527;
    box-shadow: 0 0 0 3px rgba(252, 209, 22, 0.35);
  }
  .news-item__meta time {
    color: #5b5f68;
    letter-spacing: 0.02em;
  }
  .news-item__title {
    font-size: 1.0625rem;
    line-height: 1.3;
    font-weight: 600;
    color: #0a0f1f;
    margin: 0 0 0.375rem;
  }
  .news-item__lede {
    font-size: 0.9375rem;
    color: #384251;
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .news__empty {
    padding: 1.5rem;
    text-align: center;
    color: #5b5f68;
    background: #fff;
    border: 1px dashed #e5e0d6;
    border-radius: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .news-item__link {
      transition: none;
    }
    .news-item__link:hover,
    .news-item__link:focus-visible {
      transform: none;
    }
  }
</style>
