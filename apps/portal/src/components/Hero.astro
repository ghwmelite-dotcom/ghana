---
/**
 * Hero — the homepage's emotional moment.
 *
 * Visual: a dark forest-green ground with a CSS-rendered Kente weave across
 * the bottom-right, a gold "thread" traced diagonally, and a feathered dark
 * scrim in the top-left for the editorial tagline. The weave is NOT wallpaper
 * behind body text — it's a decorative focal quadrant, per CLAUDE.md §6.3.
 *
 * Motion: entrance stagger on load (eyebrow → each tagline line → gold
 * underline drawing in → lede → search). A slow gold shimmer sweep plays once
 * every 8s to catch the eye without distraction. Respects
 * `prefers-reduced-motion: reduce` — animations collapse to instant.
 */
interface Props {
  lede?: string;
}
const {
  lede = 'Every service the government offers, every announcement it makes — in one place.',
} = Astro.props;
---

<section class="hero" aria-labelledby="hero-title">
  <!-- The Kente weave backdrop. Pure CSS; zero asset weight. -->
  <div class="hero__weave" aria-hidden="true"></div>
  <!-- Feathered dark scrim behind the text — keeps contrast at 7:1+. -->
  <div class="hero__scrim" aria-hidden="true"></div>
  <!-- A single gold thread traces diagonally on load. -->
  <svg class="hero__thread" viewBox="0 0 1200 600" preserveAspectRatio="none" aria-hidden="true">
    <path
      d="M 0 480 Q 300 320 600 380 T 1200 200"
      fill="none"
      stroke="url(#gold-thread)"
      stroke-width="1.5"
      stroke-linecap="round"></path>
    <defs>
      <linearGradient id="gold-thread" x1="0" x2="1" y1="0" y2="0">
        <stop offset="0%" stop-color="rgba(252,209,22,0)"></stop>
        <stop offset="30%" stop-color="rgba(252,209,22,0.85)"></stop>
        <stop offset="70%" stop-color="rgba(252,209,22,0.85)"></stop>
        <stop offset="100%" stop-color="rgba(252,209,22,0)"></stop>
      </linearGradient>
    </defs>
  </svg>

  <div class="hero__inner">
    <p class="hero__eyebrow">
      <span class="hero__eyebrow-dot" aria-hidden="true"></span>
      Akwaaba · Republic of Ghana
    </p>
    <h1 id="hero-title" class="hero__title">
      <span class="hero__line">One government.</span>
      <span class="hero__line">One people.</span>
      <span class="hero__line" set:html={'One <span class="hero__accent">Ghana</span>.'} />
    </h1>
    <p class="hero__lede">{lede}</p>
    <form action="/search/" method="get" role="search" class="hero__search">
      <label class="sr-only" for="hero-q">Search gov.gh</label>
      <input
        id="hero-q"
        name="q"
        type="search"
        placeholder="I am looking for…"
        autocomplete="off"
      />
      <button type="submit">
        <span>Search</span>
        <svg viewBox="0 0 16 16" aria-hidden="true" width="14" height="14">
          <path
            d="M6 11 L11 6 M6 6 h5 v5"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </button>
    </form>
  </div>

  <!-- Compositional anchor: a woven vertical kente strip on the right edge. -->
  <div class="hero__strip" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    min-height: 82vh;
    max-height: 880px;
    display: grid;
    align-items: center;
    background:
      radial-gradient(ellipse 80% 60% at 20% 30%, #004527 0%, transparent 70%),
      linear-gradient(135deg, #001a0e 0%, #002818 55%, #001008 100%);
    isolation: isolate;
  }

  /* Kente weave — plain-weave structure rendered with stacked gradients.
     Four warp colours (green / gold / red / ink) cross four weft colours
     at the same rhythm; the diagonal "over/under" illusion comes from
     alternating checker rows via background-blend-mode. */
  .hero__weave {
    position: absolute;
    inset: 0;
    opacity: 0.18;
    mix-blend-mode: screen;
    background-image:
      /* horizontal weft */
      repeating-linear-gradient(
        90deg,
        #006b3f 0 18px,
        #fcd116 18px 26px,
        #ce1126 26px 44px,
        #0b0b0f 44px 52px
      ),
      /* vertical warp */
      repeating-linear-gradient(
          0deg,
          rgba(11, 11, 15, 0.55) 0 26px,
          transparent 26px 34px,
          rgba(11, 11, 15, 0.55) 34px 52px,
          transparent 52px 60px
        );
    background-size:
      52px 52px,
      60px 60px;
    animation: weaveDrift 22s linear infinite;
    will-change: transform;
  }
  @keyframes weaveDrift {
    from {
      transform: translate3d(0, 0, 0);
    }
    to {
      transform: translate3d(-52px, -60px, 0);
    }
  }

  /* Dark feathered scrim behind the text block — readability first. */
  .hero__scrim {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 65% 70% at 28% 45%, rgba(0, 16, 8, 0.88) 0%, transparent 60%),
      linear-gradient(100deg, rgba(0, 16, 8, 0.72) 0%, transparent 55%);
    z-index: 1;
  }

  /* A gold SVG thread that strokes in on load — the signature flourish. */
  .hero__thread {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
  }
  .hero__thread path {
    stroke-dasharray: 1800;
    stroke-dashoffset: 1800;
    animation: drawThread 2.4s cubic-bezier(0.2, 0.9, 0.3, 1) 0.4s forwards;
  }
  @keyframes drawThread {
    to {
      stroke-dashoffset: 0;
    }
  }

  .hero__inner {
    position: relative;
    z-index: 3;
    padding: clamp(2.5rem, 7vw, 5rem) clamp(1.5rem, 5vw, 4.5rem);
    max-width: 58rem;
    color: #faf7f2;
  }

  .hero__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    color: #fcd116;
    text-transform: uppercase;
    margin: 0 0 1.25rem;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-weight: 600;
    opacity: 0;
    animation: rise 0.8s cubic-bezier(0.2, 0.9, 0.3, 1) 0.1s forwards;
  }
  .hero__eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #fcd116;
    box-shadow: 0 0 12px rgba(252, 209, 22, 0.6);
  }

  .hero__title {
    font-family: Georgia, 'Playfair Display', 'Source Serif Pro', serif;
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 0.95;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 1.5rem;
    color: #fffef9;
    text-shadow: 0 2px 32px rgba(0, 0, 0, 0.4);
  }
  .hero__line {
    display: block;
    opacity: 0;
    transform: translateY(24px);
    animation: rise 0.9s cubic-bezier(0.2, 0.9, 0.3, 1) forwards;
  }
  .hero__line:nth-child(1) {
    animation-delay: 0.2s;
  }
  .hero__line:nth-child(2) {
    animation-delay: 0.4s;
  }
  .hero__line:nth-child(3) {
    animation-delay: 0.6s;
  }

  /* "Ghana" gets a gold underline that draws itself in after the word appears. */
  .hero__accent {
    position: relative;
    display: inline-block;
    color: #fcd116;
  }
  .hero__accent::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.06em;
    height: 0.12em;
    background: linear-gradient(90deg, #fcd116 0%, #e0b912 100%);
    transform-origin: left;
    transform: scaleX(0);
    animation: drawUnderline 0.8s cubic-bezier(0.2, 0.9, 0.3, 1) 1.2s forwards;
  }
  @keyframes drawUnderline {
    to {
      transform: scaleX(1);
    }
  }

  .hero__lede {
    font-family: Georgia, serif;
    font-style: italic;
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    line-height: 1.5;
    max-width: 38ch;
    color: rgba(255, 253, 245, 0.82);
    margin: 0 0 2.25rem;
    opacity: 0;
    animation: rise 0.9s cubic-bezier(0.2, 0.9, 0.3, 1) 1s forwards;
  }

  .hero__search {
    display: flex;
    align-items: stretch;
    gap: 0;
    background: rgba(255, 253, 245, 0.04);
    border: 1px solid rgba(252, 209, 22, 0.35);
    border-radius: 2px;
    overflow: hidden;
    max-width: 34rem;
    backdrop-filter: blur(8px);
    transition:
      border-color 250ms ease,
      box-shadow 250ms ease;
    opacity: 0;
    animation: rise 0.9s cubic-bezier(0.2, 0.9, 0.3, 1) 1.35s forwards;
  }
  .hero__search:focus-within {
    border-color: #fcd116;
    box-shadow: 0 0 0 3px rgba(252, 209, 22, 0.25);
  }
  .hero__search input {
    flex: 1;
    border: 0;
    padding: 0.95rem 1.125rem;
    font: inherit;
    font-size: 0.9375rem;
    color: #fffef9;
    background: transparent;
  }
  .hero__search input::placeholder {
    color: rgba(255, 253, 245, 0.55);
  }
  .hero__search input:focus {
    outline: none;
  }
  .hero__search button {
    border: 0;
    background: linear-gradient(135deg, #006b3f 0%, #004527 100%);
    color: #fffef9;
    padding: 0 1.5rem;
    font: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    cursor: pointer;
    min-width: 44px;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: background 200ms ease;
    border-left: 1px solid rgba(252, 209, 22, 0.35);
  }
  .hero__search button:hover,
  .hero__search button:focus-visible {
    background: linear-gradient(135deg, #007d48 0%, #005a35 100%);
  }
  .hero__search button svg {
    transition: transform 200ms ease;
  }
  .hero__search button:hover svg {
    transform: translate(1px, -1px);
  }

  /* Vertical Kente strip on the right edge — "ever present" at low intensity. */
  .hero__strip {
    position: absolute;
    top: 0;
    bottom: 0;
    right: 0;
    width: 12px;
    background: repeating-linear-gradient(
      180deg,
      #006b3f 0 18px,
      #fcd116 18px 26px,
      #ce1126 26px 44px,
      #0b0b0f 44px 52px
    );
    opacity: 0.6;
    z-index: 3;
    box-shadow: -8px 0 24px rgba(0, 16, 8, 0.4);
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__weave {
      animation: none;
    }
    .hero__line,
    .hero__eyebrow,
    .hero__lede,
    .hero__search {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .hero__thread path {
      stroke-dashoffset: 0;
      animation: none;
    }
    .hero__accent::after {
      transform: scaleX(1);
      animation: none;
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
