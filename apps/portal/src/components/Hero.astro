---
/**
 * Hero — gov.rw-aligned: text-forward, integrated search, quiet photograph.
 *
 * Composition:
 *   - White section with generous vertical spacing.
 *   - Eyebrow + huge sans tagline + short lede + prominent search box, all
 *     left-aligned in a 62rem container.
 *   - A muted landscape photograph sits to the right on desktop, offset and
 *     sized to balance the text column without dominating it.
 *   - No constellation, no gold threads, no ken-burns — gov.rw's hero is
 *     calm and workmanlike.
 *
 * The one Ghanaian signature here is the mini-Kente underline on "Ghana"
 * (green · gold · red); everything else is flat, clean, restrained.
 */
import { Image } from 'astro:assets';
import heroArch from '../assets/photos/independence-arch.png';
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero__grid">
    <div class="hero__text">
      <p class="hero__eyebrow">
        <span aria-hidden="true" class="hero__eyebrow-star"></span>
        Akwaaba · Republic of Ghana
      </p>
      <h1 id="hero-title" class="hero__title">
        Welcome to <span class="hero__accent">Ghana</span>.
      </h1>
      <p class="hero__lede">
        The official digital portal of the Government of Ghana. Every service, every ministry, every
        announcement — in one place.
      </p>
      <form action="/search/" method="get" role="search" class="hero__search">
        <label class="sr-only" for="hero-q">Search the government of Ghana</label>
        <span aria-hidden="true" class="hero__search-icon">
          <svg viewBox="0 0 20 20" width="18" height="18" fill="none">
            <circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.6"></circle>
            <path
              d="M13.5 13.5 L17 17"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"></path>
          </svg>
        </span>
        <input
          id="hero-q"
          name="q"
          type="search"
          placeholder="Search services, ministries, news…"
          autocomplete="off"
        />
        <button type="submit">Search</button>
      </form>
    </div>
    <figure class="hero__photo-wrap" aria-hidden="true">
      <Image
        src={heroArch}
        alt=""
        widths={[480, 720, 960, 1280]}
        sizes="(min-width: 64rem) 480px, 100vw"
        loading="eager"
        fetchpriority="high"
        quality={78}
        class="hero__photo"
      />
      <figcaption class="hero__photo-caption">
        Black Star Square · Independence Arch, A.D. 1957
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .hero {
    background: #ffffff;
    padding: clamp(3rem, 7vw, 6rem) clamp(1.25rem, 4vw, 3rem);
    position: relative;
    isolation: isolate;
    border-bottom: 1px solid #edeae2;
  }
  .hero__grid {
    max-width: 80rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 3rem);
    align-items: center;
  }
  @media (min-width: 64rem) {
    .hero__grid {
      grid-template-columns: minmax(0, 1.25fr) minmax(0, 1fr);
      gap: clamp(3rem, 6vw, 5rem);
    }
  }

  .hero__text {
    max-width: 44rem;
  }
  .hero__eyebrow {
    font-size: 0.8125rem;
    letter-spacing: 0.14em;
    color: #005a35;
    text-transform: uppercase;
    margin: 0 0 1.25rem;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
  }
  .hero__eyebrow-star {
    width: 8px;
    height: 8px;
    background: #fcd116;
    display: inline-block;
    /* A tiny 5-pointed star as pseudo-marker, kept with clip-path. */
    clip-path: polygon(
      50% 0%,
      61% 35%,
      98% 35%,
      68% 57%,
      79% 91%,
      50% 70%,
      21% 91%,
      32% 57%,
      2% 35%,
      39% 35%
    );
  }

  .hero__title {
    font-size: clamp(2.5rem, 5vw, 4.25rem);
    font-weight: 700;
    letter-spacing: -0.022em;
    line-height: 1.02;
    color: #0a0f1f;
    margin: 0 0 1.25rem;
  }
  .hero__accent {
    position: relative;
    color: #005a35;
    display: inline-block;
  }
  .hero__accent::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.02em;
    height: 0.1em;
    background: linear-gradient(
      90deg,
      #006b3f 0%,
      #006b3f 33%,
      #fcd116 33%,
      #fcd116 66%,
      #ce1126 66%,
      #ce1126 100%
    );
  }

  .hero__lede {
    font-size: clamp(1.0625rem, 1.35vw, 1.25rem);
    line-height: 1.55;
    color: #384251;
    max-width: 44ch;
    margin: 0 0 2rem;
  }

  .hero__search {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: stretch;
    gap: 0;
    background: #fff;
    border: 1.5px solid #0a0f1f;
    border-radius: 4px;
    max-width: 40rem;
    overflow: hidden;
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease;
  }
  .hero__search:focus-within {
    border-color: #005a35;
    box-shadow: 0 0 0 3px rgba(252, 209, 22, 0.35);
  }
  .hero__search-icon {
    display: inline-flex;
    align-items: center;
    padding: 0 0 0 1rem;
    color: #5b5f68;
  }
  .hero__search input {
    flex: 1;
    border: 0;
    padding: 0.95rem 0.75rem 0.95rem 0.75rem;
    font: inherit;
    font-size: 0.9375rem;
    color: #0a0f1f;
    background: transparent;
    min-width: 0;
  }
  .hero__search input::placeholder {
    color: #6b7280;
  }
  .hero__search input:focus {
    outline: none;
  }
  .hero__search button {
    border: 0;
    background: #005a35;
    color: #fff;
    padding: 0 1.5rem;
    font: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition: background 180ms ease;
  }
  .hero__search button:hover,
  .hero__search button:focus-visible {
    background: #004527;
  }

  .hero__photo-wrap {
    margin: 0;
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: 6px;
    overflow: hidden;
    background: #edeae2;
    box-shadow: 0 20px 50px -20px rgba(0, 40, 24, 0.25);
    max-height: 620px;
  }
  .hero__photo-wrap :global(img.hero__photo) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 55% 50%;
  }
  .hero__photo-caption {
    position: absolute;
    bottom: 12px;
    left: 14px;
    right: 14px;
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    font-weight: 600;
    padding: 6px 10px;
    background: rgba(10, 15, 31, 0.65);
    backdrop-filter: blur(6px);
    border-radius: 2px;
  }
  @media (max-width: 64rem) {
    .hero__photo-wrap {
      max-height: 420px;
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
