---
/**
 * Hero — the homepage's emotional moment.
 *
 * Visual language: a rich forest-green ground punctuated by the iconic
 * Black Star of Africa as a large outlined monogram in the right half (≈8%
 * opacity — compositional anchor, not decoration). A single gold thread
 * traces diagonally across the hero on page load. The text sits in a dark
 * feathered scrim on the left for maximum legibility.
 *
 * Kente-as-leitmotif: the word "Ghana" gets a three-segment mini-Kente
 * underline (green · gold · red) that draws itself in after the last line
 * lands. The thicker Kente treatments elsewhere on the page (stats band
 * rails, ministries-marquee sandwich, tile threads) carry the pattern
 * through the rest of the homepage without overloading the hero.
 *
 * Motion: staggered entrance on load (eyebrow → each tagline line → gold
 * underline → lede → search). All respect `prefers-reduced-motion: reduce`.
 */
interface Props {
  lede?: string;
}
const {
  lede = 'Every service the government offers, every announcement it makes — in one place.',
} = Astro.props;
---

<section class="hero" aria-labelledby="hero-title">
  <!-- Soft grain overlay for depth. -->
  <div class="hero__grain" aria-hidden="true"></div>

  <!-- Dark feathered scrim behind the text. -->
  <div class="hero__scrim" aria-hidden="true"></div>

  <!-- The Black Star of Africa — outline monogram as compositional anchor. -->
  <svg
    class="hero__star"
    viewBox="0 0 200 200"
    aria-hidden="true"
    preserveAspectRatio="xMidYMid meet"
  >
    <path
      d="M 100 14 L 122.4 80.9 L 193.1 80.9 L 135.4 122.2 L 157.8 189.1 L 100 147.8 L 42.2 189.1 L 64.6 122.2 L 6.9 80.9 L 77.6 80.9 Z"
      fill="none"
      stroke="rgba(252,209,22,0.22)"
      stroke-width="0.8"
      stroke-linejoin="round"></path>
    <path
      d="M 100 14 L 122.4 80.9 L 193.1 80.9 L 135.4 122.2 L 157.8 189.1 L 100 147.8 L 42.2 189.1 L 64.6 122.2 L 6.9 80.9 L 77.6 80.9 Z"
      fill="rgba(11,11,15,0.18)"
      stroke="none"></path>
  </svg>

  <!-- A single gold thread traces in on load. -->
  <svg class="hero__thread" viewBox="0 0 1200 600" preserveAspectRatio="none" aria-hidden="true">
    <path
      d="M 0 480 Q 300 320 600 380 T 1200 200"
      fill="none"
      stroke="url(#gold-thread)"
      stroke-width="1.5"
      stroke-linecap="round"></path>
    <defs>
      <linearGradient id="gold-thread" x1="0" x2="1" y1="0" y2="0">
        <stop offset="0%" stop-color="rgba(252,209,22,0)"></stop>
        <stop offset="35%" stop-color="rgba(252,209,22,0.85)"></stop>
        <stop offset="65%" stop-color="rgba(252,209,22,0.85)"></stop>
        <stop offset="100%" stop-color="rgba(252,209,22,0)"></stop>
      </linearGradient>
    </defs>
  </svg>

  <div class="hero__inner">
    <p class="hero__eyebrow">
      <span class="hero__eyebrow-dot" aria-hidden="true"></span>
      Akwaaba · Republic of Ghana
    </p>
    <h1 id="hero-title" class="hero__title">
      <span class="hero__line">One government.</span>
      <span class="hero__line">One people.</span>
      <span class="hero__line" set:html={'One <span class="hero__accent">Ghana</span>.'} />
    </h1>
    <p class="hero__lede">{lede}</p>
    <form action="/search/" method="get" role="search" class="hero__search">
      <label class="sr-only" for="hero-q">Search gov.gh</label>
      <input
        id="hero-q"
        name="q"
        type="search"
        placeholder="I am looking for…"
        autocomplete="off"
      />
      <button type="submit">
        <span>Search</span>
        <svg viewBox="0 0 16 16" aria-hidden="true" width="14" height="14">
          <path
            d="M6 11 L11 6 M6 6 h5 v5"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </button>
    </form>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    min-height: 82vh;
    max-height: 880px;
    display: grid;
    align-items: center;
    background:
      radial-gradient(ellipse 75% 65% at 22% 35%, #005a35 0%, transparent 70%),
      radial-gradient(ellipse 60% 50% at 85% 70%, #003a22 0%, transparent 65%),
      linear-gradient(135deg, #001a0e 0%, #002818 55%, #001008 100%);
    isolation: isolate;
  }

  /* Subtle grain — dot pattern at very low opacity adds depth without noise. */
  .hero__grain {
    position: absolute;
    inset: 0;
    opacity: 0.5;
    background-image: radial-gradient(
      circle at 1px 1px,
      rgba(252, 209, 22, 0.035) 1px,
      transparent 0
    );
    background-size: 3px 3px;
    mix-blend-mode: screen;
  }

  /* Dark feathered scrim behind the text block — readability first. */
  .hero__scrim {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 65% 70% at 30% 45%, rgba(0, 16, 8, 0.75) 0%, transparent 65%),
      linear-gradient(100deg, rgba(0, 16, 8, 0.55) 0%, transparent 55%);
    z-index: 1;
  }

  /* The Black Star — the compositional anchor of the right half. */
  .hero__star {
    position: absolute;
    top: 50%;
    right: -8%;
    transform: translateY(-50%);
    width: clamp(420px, 62vw, 720px);
    height: clamp(420px, 62vw, 720px);
    z-index: 2;
    pointer-events: none;
    animation: starFadeIn 1.6s cubic-bezier(0.2, 0.9, 0.3, 1) 0.3s both;
  }
  @keyframes starFadeIn {
    from {
      opacity: 0;
      transform: translateY(-50%) scale(0.94) rotate(-4deg);
    }
    to {
      opacity: 1;
      transform: translateY(-50%) scale(1) rotate(0deg);
    }
  }

  /* A gold SVG thread that strokes in on load — the signature flourish. */
  .hero__thread {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
  }
  .hero__thread path {
    stroke-dasharray: 1800;
    stroke-dashoffset: 1800;
    animation: drawThread 2.4s cubic-bezier(0.2, 0.9, 0.3, 1) 0.4s forwards;
  }
  @keyframes drawThread {
    to {
      stroke-dashoffset: 0;
    }
  }

  .hero__inner {
    position: relative;
    z-index: 3;
    padding: clamp(2.5rem, 7vw, 5rem) clamp(1.5rem, 5vw, 4.5rem);
    max-width: 58rem;
    color: #faf7f2;
  }

  .hero__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    color: #fcd116;
    text-transform: uppercase;
    margin: 0 0 1.25rem;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-weight: 600;
    opacity: 0;
    animation: rise 0.8s cubic-bezier(0.2, 0.9, 0.3, 1) 0.1s forwards;
  }
  .hero__eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #fcd116;
    box-shadow: 0 0 12px rgba(252, 209, 22, 0.6);
  }

  .hero__title {
    font-family: Georgia, 'Playfair Display', 'Source Serif Pro', serif;
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 0.95;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 1.5rem;
    color: #fffef9;
    text-shadow: 0 2px 32px rgba(0, 0, 0, 0.5);
  }
  .hero__line {
    display: block;
    opacity: 0;
    transform: translateY(24px);
    animation: rise 0.9s cubic-bezier(0.2, 0.9, 0.3, 1) forwards;
  }
  .hero__line:nth-child(1) {
    animation-delay: 0.2s;
  }
  .hero__line:nth-child(2) {
    animation-delay: 0.4s;
  }
  .hero__line:nth-child(3) {
    animation-delay: 0.6s;
  }

  /* "Ghana" gets a three-segment mini-Kente underline — green / gold / red,
     drawn in after the word appears. The underline IS the one place we let
     Kente live in the hero. */
  .hero__accent {
    position: relative;
    display: inline-block;
    color: #fcd116;
  }
  .hero__accent::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.02em;
    height: 0.14em;
    background: linear-gradient(
      90deg,
      #006b3f 0%,
      #006b3f 33%,
      #fcd116 33%,
      #fcd116 66%,
      #ce1126 66%,
      #ce1126 100%
    );
    transform-origin: left;
    transform: scaleX(0);
    animation: drawUnderline 1s cubic-bezier(0.2, 0.9, 0.3, 1) 1.2s forwards;
  }
  @keyframes drawUnderline {
    to {
      transform: scaleX(1);
    }
  }

  .hero__lede {
    font-family: Georgia, serif;
    font-style: italic;
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    line-height: 1.55;
    max-width: 38ch;
    color: rgba(255, 253, 245, 0.85);
    margin: 0 0 2.25rem;
    opacity: 0;
    animation: rise 0.9s cubic-bezier(0.2, 0.9, 0.3, 1) 1s forwards;
  }

  .hero__search {
    display: flex;
    align-items: stretch;
    gap: 0;
    background: rgba(255, 253, 245, 0.05);
    border: 1px solid rgba(252, 209, 22, 0.38);
    border-radius: 2px;
    overflow: hidden;
    max-width: 34rem;
    backdrop-filter: blur(8px);
    transition:
      border-color 250ms ease,
      box-shadow 250ms ease;
    opacity: 0;
    animation: rise 0.9s cubic-bezier(0.2, 0.9, 0.3, 1) 1.35s forwards;
  }
  .hero__search:focus-within {
    border-color: #fcd116;
    box-shadow: 0 0 0 3px rgba(252, 209, 22, 0.25);
  }
  .hero__search input {
    flex: 1;
    border: 0;
    padding: 0.95rem 1.125rem;
    font: inherit;
    font-size: 0.9375rem;
    color: #fffef9;
    background: transparent;
  }
  .hero__search input::placeholder {
    color: rgba(255, 253, 245, 0.55);
  }
  .hero__search input:focus {
    outline: none;
  }
  .hero__search button {
    border: 0;
    background: linear-gradient(135deg, #006b3f 0%, #004527 100%);
    color: #fffef9;
    padding: 0 1.5rem;
    font: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    cursor: pointer;
    min-width: 44px;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: background 200ms ease;
    border-left: 1px solid rgba(252, 209, 22, 0.38);
  }
  .hero__search button:hover,
  .hero__search button:focus-visible {
    background: linear-gradient(135deg, #007d48 0%, #005a35 100%);
  }
  .hero__search button svg {
    transition: transform 200ms ease;
  }
  .hero__search button:hover svg {
    transform: translate(1px, -1px);
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__line,
    .hero__eyebrow,
    .hero__lede,
    .hero__search,
    .hero__star {
      opacity: 1;
      transform: translateY(-50%);
      animation: none;
    }
    .hero__line,
    .hero__eyebrow,
    .hero__lede,
    .hero__search {
      transform: none;
    }
    .hero__thread path {
      stroke-dashoffset: 0;
      animation: none;
    }
    .hero__accent::after {
      transform: scaleX(1);
      animation: none;
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
