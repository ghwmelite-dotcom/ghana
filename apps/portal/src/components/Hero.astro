---
/**
 * Hero — the homepage's emotional moment, national-scale edition.
 *
 * Visual language: a deep forest-green ground where the Black Star of Africa
 * sits at the right as a luminous centerpiece — breathing, slowly rotating,
 * with a gold highlight that sweeps across it like sunlight across bronze.
 * A constellation of smaller stars floats around it at low opacity (Ghana
 * IS the Black Star of Africa — lean in). Three gold threads trace
 * diagonally on load in orchestrated succession. Each tagline line reveals
 * through a clip-path curtain-wipe rather than a plain fade.
 *
 * Kente lives in one place here: the mini-Kente underline under "Ghana"
 * (green / gold / red) that draws in after the last line lands. The richer
 * Kente treatments stay in the stats band, marquee, and tile threads.
 *
 * Performance: every animation is CSS transform + opacity only —
 * GPU-composited, zero layout thrash. No new asset weight. Respects
 * `prefers-reduced-motion: reduce` — animations collapse to instant.
 */
interface Props {
  lede?: string;
}
const {
  lede = 'Every service the government offers, every announcement it makes — in one place.',
} = Astro.props;

/**
 * Five-pointed star path, normalised to a 200×200 viewBox. Reused by the
 * big centerpiece and the constellation so we stay on-brand.
 */
const STAR_PATH =
  'M 100 14 L 122.4 80.9 L 193.1 80.9 L 135.4 122.2 L 157.8 189.1 L 100 147.8 L 42.2 189.1 L 64.6 122.2 L 6.9 80.9 L 77.6 80.9 Z';

/**
 * Constellation — hand-placed coordinates so the arrangement feels designed,
 * not random. Sizes vary; the brightest 4 twinkle at different cadences so
 * the sky feels alive.
 */
const constellation: ReadonlyArray<{ x: number; y: number; size: number; twinkle?: number }> = [
  { x: 8, y: 18, size: 10 },
  { x: 14, y: 72, size: 6 },
  { x: 28, y: 8, size: 7, twinkle: 0 },
  { x: 34, y: 88, size: 8 },
  { x: 46, y: 24, size: 5 },
  { x: 42, y: 64, size: 9, twinkle: 1 },
  { x: 56, y: 80, size: 6 },
  { x: 62, y: 14, size: 11, twinkle: 2 },
  { x: 68, y: 48, size: 5 },
  { x: 76, y: 86, size: 7 },
  { x: 88, y: 18, size: 8 },
  { x: 92, y: 56, size: 6, twinkle: 3 },
];
---

<section class="hero" aria-labelledby="hero-title">
  <!-- Ambient drifting gradients give the ground a sense of depth + life. -->
  <div class="hero__ground" aria-hidden="true"></div>
  <div class="hero__grain" aria-hidden="true"></div>

  <!-- Constellation — small stars scattered across the sky. -->
  <div class="hero__sky" aria-hidden="true">
    {
      constellation.map((s) => (
        <svg
          class={`star-sm${s.twinkle !== undefined ? ` star-sm--twinkle-${s.twinkle}` : ''}`}
          viewBox="0 0 200 200"
          style={`--x:${s.x}%; --y:${s.y}%; --s:${s.size}px;`}
          preserveAspectRatio="xMidYMid meet"
        >
          <path d={STAR_PATH} fill="rgba(252,209,22,0.35)" />
        </svg>
      ))
    }
  </div>

  <!-- Dark feathered scrim behind the text block. -->
  <div class="hero__scrim" aria-hidden="true"></div>

  <!-- The Black Star of Africa — breathing, rotating, catching light. -->
  <div class="hero__star" aria-hidden="true">
    <svg viewBox="0 0 200 200" class="hero__star-glow" preserveAspectRatio="xMidYMid meet">
      <defs>
        <radialGradient id="star-glow" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="rgba(252,209,22,0.45)"></stop>
          <stop offset="45%" stop-color="rgba(252,209,22,0.12)"></stop>
          <stop offset="100%" stop-color="rgba(252,209,22,0)"></stop>
        </radialGradient>
      </defs>
      <circle cx="100" cy="100" r="100" fill="url(#star-glow)"></circle>
    </svg>
    <svg viewBox="0 0 200 200" class="hero__star-shape" preserveAspectRatio="xMidYMid meet">
      <path
        d={STAR_PATH}
        fill="rgba(11,11,15,0.55)"
        stroke="rgba(252,209,22,0.32)"
        stroke-width="0.8"
        stroke-linejoin="round"></path>
    </svg>
    <!-- Specular highlight — a small bright disc that drifts diagonally across
         the star, giving it the feeling of sunlight gliding over bronze. -->
    <div class="hero__star-specular"></div>
  </div>

  <!-- Three gold threads trace in on load at staggered delays — orchestration. -->
  <svg class="hero__threads" viewBox="0 0 1200 600" preserveAspectRatio="none" aria-hidden="true">
    <defs>
      <linearGradient id="thread-a" x1="0" x2="1" y1="0" y2="0">
        <stop offset="0%" stop-color="rgba(252,209,22,0)"></stop>
        <stop offset="35%" stop-color="rgba(252,209,22,0.85)"></stop>
        <stop offset="65%" stop-color="rgba(252,209,22,0.85)"></stop>
        <stop offset="100%" stop-color="rgba(252,209,22,0)"></stop>
      </linearGradient>
      <linearGradient id="thread-b" x1="0" x2="1" y1="0" y2="0">
        <stop offset="0%" stop-color="rgba(252,209,22,0)"></stop>
        <stop offset="40%" stop-color="rgba(252,209,22,0.55)"></stop>
        <stop offset="60%" stop-color="rgba(252,209,22,0.55)"></stop>
        <stop offset="100%" stop-color="rgba(252,209,22,0)"></stop>
      </linearGradient>
      <linearGradient id="thread-c" x1="0" x2="1" y1="0" y2="0">
        <stop offset="0%" stop-color="rgba(206,17,38,0)"></stop>
        <stop offset="45%" stop-color="rgba(206,17,38,0.35)"></stop>
        <stop offset="55%" stop-color="rgba(206,17,38,0.35)"></stop>
        <stop offset="100%" stop-color="rgba(206,17,38,0)"></stop>
      </linearGradient>
    </defs>
    <path
      class="thread thread--a"
      d="M 0 480 Q 300 320 600 380 T 1200 200"
      fill="none"
      stroke="url(#thread-a)"
      stroke-width="1.5"
      stroke-linecap="round"></path>
    <path
      class="thread thread--b"
      d="M 0 560 Q 360 460 680 500 T 1200 360"
      fill="none"
      stroke="url(#thread-b)"
      stroke-width="1"
      stroke-linecap="round"></path>
    <path
      class="thread thread--c"
      d="M 0 280 Q 280 180 580 220 T 1200 80"
      fill="none"
      stroke="url(#thread-c)"
      stroke-width="0.75"
      stroke-linecap="round"></path>
  </svg>

  <div class="hero__inner">
    <p class="hero__eyebrow">
      <span class="hero__eyebrow-dot" aria-hidden="true"></span>
      Akwaaba · Republic of Ghana
    </p>
    <h1 id="hero-title" class="hero__title">
      <span class="hero__line"><span class="hero__line-inner">One government.</span></span>
      <span class="hero__line"><span class="hero__line-inner">One people.</span></span>
      <span class="hero__line">
        <span class="hero__line-inner" set:html={'One <span class="hero__accent">Ghana</span>.'} />
      </span>
    </h1>
    <p class="hero__lede">{lede}</p>
    <form action="/search/" method="get" role="search" class="hero__search">
      <label class="sr-only" for="hero-q">Search gov.gh</label>
      <input
        id="hero-q"
        name="q"
        type="search"
        placeholder="I am looking for…"
        autocomplete="off"
      />
      <button type="submit">
        <span>Search</span>
        <svg viewBox="0 0 16 16" aria-hidden="true" width="14" height="14">
          <path
            d="M6 11 L11 6 M6 6 h5 v5"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </button>
    </form>
  </div>

  <!-- Scroll affordance. -->
  <div class="hero__scroll" aria-hidden="true">
    <span class="hero__scroll-label">Explore</span>
    <span class="hero__scroll-dot"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    min-height: 86vh;
    max-height: 920px;
    display: grid;
    align-items: center;
    background: #001008;
    isolation: isolate;
    color: #fffef9;
  }

  /* Ambient ground — two layered radial gradients that slowly drift.
     Subtle enough to be felt rather than seen. */
  .hero__ground {
    position: absolute;
    inset: -10%;
    background:
      radial-gradient(ellipse 70% 55% at 25% 35%, #005a35 0%, transparent 70%),
      radial-gradient(ellipse 55% 45% at 85% 70%, #003a22 0%, transparent 65%),
      radial-gradient(ellipse 40% 30% at 60% 20%, rgba(252, 209, 22, 0.08) 0%, transparent 60%),
      linear-gradient(135deg, #001a0e 0%, #002818 55%, #001008 100%);
    animation: groundDrift 38s ease-in-out infinite alternate;
    z-index: 0;
  }
  @keyframes groundDrift {
    from {
      transform: translate3d(0, 0, 0) scale(1);
    }
    to {
      transform: translate3d(2%, -2%, 0) scale(1.02);
    }
  }

  /* Subtle dot grain. */
  .hero__grain {
    position: absolute;
    inset: 0;
    opacity: 0.5;
    background-image: radial-gradient(
      circle at 1px 1px,
      rgba(252, 209, 22, 0.04) 1px,
      transparent 0
    );
    background-size: 3px 3px;
    mix-blend-mode: screen;
    z-index: 1;
  }

  /* Constellation — small outline stars scattered across the sky. Four of
     them twinkle at different cadences, giving the scene a quiet pulse. */
  .hero__sky {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }
  .star-sm {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--s);
    height: var(--s);
    opacity: 0.35;
    transform: translate(-50%, -50%);
    animation: starDrift 16s ease-in-out infinite alternate;
  }
  .star-sm--twinkle-0 {
    animation: twinkle 4.5s ease-in-out 0.2s infinite;
    opacity: 0.55;
  }
  .star-sm--twinkle-1 {
    animation: twinkle 6.2s ease-in-out 1.1s infinite;
    opacity: 0.6;
  }
  .star-sm--twinkle-2 {
    animation: twinkle 5.1s ease-in-out 2.4s infinite;
    opacity: 0.7;
  }
  .star-sm--twinkle-3 {
    animation: twinkle 7s ease-in-out 0.6s infinite;
    opacity: 0.5;
  }
  @keyframes starDrift {
    from {
      transform: translate(-50%, -50%) translateY(0);
    }
    to {
      transform: translate(-50%, -50%) translateY(-6px);
    }
  }
  @keyframes twinkle {
    0%,
    100% {
      opacity: 0.35;
      transform: translate(-50%, -50%) scale(1);
    }
    50% {
      opacity: 0.9;
      transform: translate(-50%, -50%) scale(1.35);
    }
  }

  /* Dark feathered scrim behind text — locks contrast. */
  .hero__scrim {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 65% 70% at 28% 48%, rgba(0, 16, 8, 0.8) 0%, transparent 62%),
      linear-gradient(100deg, rgba(0, 16, 8, 0.58) 0%, transparent 55%);
    z-index: 2;
  }

  /* The Black Star — the hero's emotional centerpiece. */
  .hero__star {
    position: absolute;
    top: 50%;
    right: -6%;
    transform: translateY(-50%);
    width: clamp(420px, 62vw, 720px);
    height: clamp(420px, 62vw, 720px);
    z-index: 2;
    pointer-events: none;
    animation: starEnter 1.8s cubic-bezier(0.2, 0.9, 0.3, 1) 0.3s both;
  }
  @keyframes starEnter {
    from {
      opacity: 0;
      transform: translateY(-50%) scale(0.92) rotate(-6deg);
    }
    to {
      opacity: 1;
      transform: translateY(-50%) scale(1) rotate(0deg);
    }
  }

  /* A soft radial glow behind the star — the halo. */
  .hero__star-glow {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.85;
    animation: haloPulse 10s ease-in-out infinite;
  }
  @keyframes haloPulse {
    0%,
    100% {
      opacity: 0.75;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.05);
    }
  }

  /* The star itself — a slow breathing rotation that never stops. */
  .hero__star-shape {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    animation: starBreath 24s ease-in-out infinite;
  }
  @keyframes starBreath {
    0%,
    100% {
      transform: scale(1) rotate(0deg);
    }
    33% {
      transform: scale(1.015) rotate(0.6deg);
    }
    66% {
      transform: scale(1.01) rotate(-0.8deg);
    }
  }

  /* Specular highlight — a bright disc drifts diagonally across the star,
     creating the "sunlight on bronze" effect. Masked to stay inside the
     star's bounding circle. */
  .hero__star-specular {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    overflow: hidden;
    pointer-events: none;
  }
  .hero__star-specular::before {
    content: '';
    position: absolute;
    width: 55%;
    height: 55%;
    top: -40%;
    left: -40%;
    background: radial-gradient(
      ellipse 60% 50% at 50% 50%,
      rgba(252, 209, 22, 0.42) 0%,
      rgba(252, 209, 22, 0.1) 40%,
      transparent 70%
    );
    filter: blur(18px);
    animation: specularSweep 12s cubic-bezier(0.45, 0, 0.55, 1) infinite;
  }
  @keyframes specularSweep {
    0% {
      top: -40%;
      left: -40%;
      opacity: 0;
    }
    15% {
      opacity: 1;
    }
    85% {
      opacity: 1;
    }
    100% {
      top: 85%;
      left: 85%;
      opacity: 0;
    }
  }

  /* Gold threads — three of them, staggered. */
  .hero__threads {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
  }
  .thread {
    stroke-dasharray: 1800;
    stroke-dashoffset: 1800;
    animation: drawThread 2.6s cubic-bezier(0.2, 0.9, 0.3, 1) forwards;
  }
  .thread--a {
    animation-delay: 0.4s;
  }
  .thread--b {
    animation-delay: 0.7s;
  }
  .thread--c {
    animation-delay: 1s;
  }
  @keyframes drawThread {
    to {
      stroke-dashoffset: 0;
    }
  }

  .hero__inner {
    position: relative;
    z-index: 3;
    padding: clamp(2.5rem, 7vw, 5rem) clamp(1.5rem, 5vw, 4.5rem);
    max-width: 58rem;
    color: #faf7f2;
  }

  .hero__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    color: #fcd116;
    text-transform: uppercase;
    margin: 0 0 1.25rem;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-weight: 600;
    opacity: 0;
    animation: rise 0.8s cubic-bezier(0.2, 0.9, 0.3, 1) 0.1s forwards;
  }
  .hero__eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #fcd116;
    box-shadow: 0 0 12px rgba(252, 209, 22, 0.6);
    animation: eyebrowDotPulse 2.8s ease-in-out 1.6s infinite;
  }
  @keyframes eyebrowDotPulse {
    0%,
    100% {
      box-shadow: 0 0 12px rgba(252, 209, 22, 0.6);
      transform: scale(1);
    }
    50% {
      box-shadow: 0 0 22px rgba(252, 209, 22, 0.95);
      transform: scale(1.25);
    }
  }

  .hero__title {
    font-family: Georgia, 'Playfair Display', 'Source Serif Pro', serif;
    font-size: clamp(2.5rem, 7vw, 5.75rem);
    line-height: 0.96;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 1.5rem;
    color: #fffef9;
    text-shadow: 0 2px 32px rgba(0, 0, 0, 0.5);
  }
  /* Clip-path curtain reveal — each line wipes open left-to-right instead of
     plain-fading. Feels like stage curtains rising. */
  .hero__line {
    display: block;
    overflow: hidden;
    clip-path: inset(0 100% 0 0);
    animation: curtain 0.95s cubic-bezier(0.2, 0.9, 0.3, 1) forwards;
  }
  .hero__line:nth-child(1) {
    animation-delay: 0.25s;
  }
  .hero__line:nth-child(2) {
    animation-delay: 0.5s;
  }
  .hero__line:nth-child(3) {
    animation-delay: 0.75s;
  }
  @keyframes curtain {
    to {
      clip-path: inset(0 0 0 0);
    }
  }
  /* Secondary rise of the inner word adds lift through the clip reveal. */
  .hero__line-inner {
    display: inline-block;
    transform: translateY(20px);
    opacity: 0.4;
    animation: lineLift 0.95s cubic-bezier(0.2, 0.9, 0.3, 1) forwards;
  }
  .hero__line:nth-child(1) .hero__line-inner {
    animation-delay: 0.25s;
  }
  .hero__line:nth-child(2) .hero__line-inner {
    animation-delay: 0.5s;
  }
  .hero__line:nth-child(3) .hero__line-inner {
    animation-delay: 0.75s;
  }
  @keyframes lineLift {
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  /* "Ghana" — three-segment mini-Kente underline. */
  .hero__accent {
    position: relative;
    display: inline-block;
    color: #fcd116;
  }
  .hero__accent::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.02em;
    height: 0.14em;
    background: linear-gradient(
      90deg,
      #006b3f 0%,
      #006b3f 33%,
      #fcd116 33%,
      #fcd116 66%,
      #ce1126 66%,
      #ce1126 100%
    );
    transform-origin: left;
    transform: scaleX(0);
    animation: drawUnderline 1.1s cubic-bezier(0.2, 0.9, 0.3, 1) 1.35s forwards;
  }
  @keyframes drawUnderline {
    to {
      transform: scaleX(1);
    }
  }

  .hero__lede {
    font-family: Georgia, serif;
    font-style: italic;
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    line-height: 1.55;
    max-width: 38ch;
    color: rgba(255, 253, 245, 0.85);
    margin: 0 0 2.25rem;
    opacity: 0;
    animation: rise 0.9s cubic-bezier(0.2, 0.9, 0.3, 1) 1.15s forwards;
  }

  .hero__search {
    display: flex;
    align-items: stretch;
    gap: 0;
    background: rgba(255, 253, 245, 0.05);
    border: 1px solid rgba(252, 209, 22, 0.38);
    border-radius: 2px;
    overflow: hidden;
    max-width: 34rem;
    backdrop-filter: blur(8px);
    transition:
      border-color 250ms ease,
      box-shadow 250ms ease;
    opacity: 0;
    animation: rise 0.9s cubic-bezier(0.2, 0.9, 0.3, 1) 1.5s forwards;
  }
  .hero__search:focus-within {
    border-color: #fcd116;
    box-shadow: 0 0 0 3px rgba(252, 209, 22, 0.25);
  }
  .hero__search input {
    flex: 1;
    border: 0;
    padding: 0.95rem 1.125rem;
    font: inherit;
    font-size: 0.9375rem;
    color: #fffef9;
    background: transparent;
  }
  .hero__search input::placeholder {
    color: rgba(255, 253, 245, 0.55);
  }
  .hero__search input:focus {
    outline: none;
  }
  .hero__search button {
    border: 0;
    background: linear-gradient(135deg, #006b3f 0%, #004527 100%);
    color: #fffef9;
    padding: 0 1.5rem;
    font: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    cursor: pointer;
    min-width: 44px;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: background 200ms ease;
    border-left: 1px solid rgba(252, 209, 22, 0.38);
  }
  .hero__search button:hover,
  .hero__search button:focus-visible {
    background: linear-gradient(135deg, #007d48 0%, #005a35 100%);
  }
  .hero__search button svg {
    transition: transform 200ms ease;
  }
  .hero__search button:hover svg {
    transform: translate(1px, -1px);
  }

  /* "Explore" scroll affordance — bottom-centre. */
  .hero__scroll {
    position: absolute;
    bottom: 1.75rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 253, 245, 0.55);
    font-size: 0.6875rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    font-weight: 600;
    opacity: 0;
    animation: rise 1s cubic-bezier(0.2, 0.9, 0.3, 1) 2s forwards;
  }
  .hero__scroll-label {
    writing-mode: horizontal-tb;
  }
  .hero__scroll-dot {
    width: 2px;
    height: 32px;
    background: linear-gradient(180deg, rgba(252, 209, 22, 0.8) 0%, transparent 100%);
    animation: scrollDot 2.4s ease-in-out infinite;
  }
  @keyframes scrollDot {
    0%,
    100% {
      transform: translateY(0);
      opacity: 0.4;
    }
    50% {
      transform: translateY(6px);
      opacity: 1;
    }
  }
  @media (max-width: 48rem) {
    .hero__scroll {
      display: none;
    }
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Reduced-motion: strip everything non-essential. */
  @media (prefers-reduced-motion: reduce) {
    .hero__ground,
    .hero__star-glow,
    .hero__star-shape,
    .hero__star-specular::before,
    .star-sm,
    .hero__eyebrow-dot,
    .hero__scroll-dot {
      animation: none !important;
    }
    .hero__star {
      animation: none;
      opacity: 1;
      transform: translateY(-50%);
    }
    .hero__line {
      clip-path: none;
      animation: none;
    }
    .hero__line-inner,
    .hero__eyebrow,
    .hero__lede,
    .hero__search,
    .hero__scroll {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .thread {
      stroke-dashoffset: 0;
      animation: none;
    }
    .hero__accent::after {
      transform: scaleX(1);
      animation: none;
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
