---
/**
 * Life-stage tiles — gov.rw-aligned 4-column card grid.
 *
 * Each tile is a clean white card with a simple line-icon in the top-left,
 * a sans heading, a short descriptor, and a "Read more →" link. Hover
 * subtly lifts and tints the top border green.
 */
interface Tile {
  href: string;
  label: string;
  descriptor: string;
  icon: 'live' | 'work' | 'business' | 'visit';
}

const tiles: ReadonlyArray<Tile> = [
  {
    href: '/services/live/',
    label: 'Live in Ghana',
    descriptor: 'Identity, health, housing, family — everyday services for citizens and residents.',
    icon: 'live',
  },
  {
    href: '/services/work/',
    label: 'Work in Ghana',
    descriptor: 'Tax, pensions, professional permits, national service postings.',
    icon: 'work',
  },
  {
    href: '/services/business/',
    label: 'Do business in Ghana',
    descriptor: 'Register a company, obtain licences, file returns, import and export.',
    icon: 'business',
  },
  {
    href: '/services/visit/',
    label: 'Visit Ghana',
    descriptor: 'Passports, visas, residence permits, diaspora and Year of Return.',
    icon: 'visit',
  },
];
---

<section class="tiles" aria-labelledby="tiles-heading">
  <div class="tiles__inner">
    <header class="tiles__head">
      <p class="tiles__eyebrow">Services</p>
      <h2 id="tiles-heading" class="tiles__title">Start with a moment of your life.</h2>
      <p class="tiles__lede">
        Every service the Government of Ghana offers, grouped by what you need to do.
      </p>
    </header>

    <div class="tiles__grid">
      {
        tiles.map((tile) => (
          <a href={tile.href} class="tile">
            <span class="tile__icon" aria-hidden="true">
              {tile.icon === 'live' && (
                <svg viewBox="0 0 32 32" width="28" height="28" fill="none">
                  <circle cx="16" cy="11" r="5" stroke="currentColor" stroke-width="1.6" />
                  <path
                    d="M5 28 Q 5 17 16 17 T 27 28"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                  />
                </svg>
              )}
              {tile.icon === 'work' && (
                <svg viewBox="0 0 32 32" width="28" height="28" fill="none">
                  <path
                    d="M5 10 h22 v17 h-22 z M11 10 v-3 h10 v3"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linejoin="round"
                  />
                  <path d="M5 18 h22" stroke="currentColor" stroke-width="1.6" />
                </svg>
              )}
              {tile.icon === 'business' && (
                <svg viewBox="0 0 32 32" width="28" height="28" fill="none">
                  <path
                    d="M6 27 V13 L13 13 V8 L19 8 V15 L26 15 V27 Z"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linejoin="round"
                  />
                  <path
                    d="M10 27 v-4 h3 v4 M16 27 v-4 h3 v4 M22 27 v-4 h2 v4"
                    stroke="currentColor"
                    stroke-width="1.4"
                  />
                </svg>
              )}
              {tile.icon === 'visit' && (
                <svg viewBox="0 0 32 32" width="28" height="28" fill="none">
                  <path
                    d="M4 17 L27 7 L23 18 L17 17 L13 22 L11 17 Z"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linejoin="round"
                  />
                </svg>
              )}
            </span>
            <h3 class="tile__label">{tile.label}</h3>
            <p class="tile__descriptor">{tile.descriptor}</p>
            <span class="tile__more" aria-hidden="true">
              Explore
              <svg viewBox="0 0 16 16" width="12" height="12" fill="none">
                <path
                  d="M3 8 h10 M9 4 l4 4 -4 4"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .tiles {
    background: #f7f7f5;
    padding: clamp(3rem, 6vw, 5rem) clamp(1.25rem, 4vw, 3rem);
    border-bottom: 1px solid #edeae2;
  }
  .tiles__inner {
    max-width: 80rem;
    margin: 0 auto;
  }
  .tiles__head {
    max-width: 50ch;
    margin-bottom: clamp(1.75rem, 3vw, 2.5rem);
  }
  .tiles__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: #005a35;
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 0.625rem;
  }
  .tiles__title {
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    font-weight: 700;
    color: #0a0f1f;
    margin: 0 0 0.625rem;
    letter-spacing: -0.015em;
  }
  .tiles__lede {
    color: #384251;
    max-width: 52ch;
    margin: 0;
    font-size: 1rem;
    line-height: 1.55;
  }

  .tiles__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 36rem) {
    .tiles__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 64rem) {
    .tiles__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .tile {
    background: #fff;
    border: 1px solid #e5e0d6;
    border-top: 3px solid #005a35;
    border-radius: 4px;
    padding: 1.5rem 1.375rem 1.375rem;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    min-height: 220px;
    transition:
      transform 200ms cubic-bezier(0.2, 0.9, 0.3, 1),
      box-shadow 200ms ease,
      border-top-color 200ms ease;
  }
  .tile:hover,
  .tile:focus-visible {
    transform: translateY(-3px);
    box-shadow: 0 14px 32px -16px rgba(0, 40, 24, 0.18);
    border-top-color: #fcd116;
  }
  .tile:focus-visible {
    outline: 3px solid #fcd116;
    outline-offset: 3px;
  }
  .tile__icon {
    color: #005a35;
    display: inline-flex;
    margin-bottom: 1rem;
  }
  .tile__label {
    font-size: 1.125rem;
    font-weight: 600;
    color: #0a0f1f;
    margin: 0 0 0.5rem;
    line-height: 1.25;
  }
  .tile__descriptor {
    font-size: 0.9375rem;
    color: #384251;
    line-height: 1.45;
    margin: 0 0 1.25rem;
    flex: 1;
  }
  .tile__more {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #005a35;
    text-decoration: none;
  }
  .tile__more svg {
    transition: transform 200ms cubic-bezier(0.2, 0.9, 0.3, 1);
  }
  .tile:hover .tile__more svg,
  .tile:focus-visible .tile__more svg {
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    .tile,
    .tile__more svg {
      transition: none;
    }
    .tile:hover,
    .tile:focus-visible {
      transform: none;
    }
  }
</style>
