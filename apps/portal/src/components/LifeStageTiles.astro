---
/**
 * 4 life-stage tiles — primary category nav on the homepage and on
 * `/services/`. Each tile links to its category landing.
 */
interface Tile {
  href: string;
  label: string;
  descriptor: string;
  colour: 'green' | 'red' | 'gold' | 'black';
  emoji: string;
}

const tiles: ReadonlyArray<Tile> = [
  {
    href: '/services/live/',
    label: 'Live',
    descriptor: 'ID · health · housing · family',
    colour: 'green',
    emoji: '👤',
  },
  {
    href: '/services/work/',
    label: 'Work',
    descriptor: 'tax · jobs · pensions',
    colour: 'red',
    emoji: '💼',
  },
  {
    href: '/services/business/',
    label: 'Do business',
    descriptor: 'register · licences · trade',
    colour: 'gold',
    emoji: '🏢',
  },
  {
    href: '/services/visit/',
    label: 'Visit',
    descriptor: 'visa · tourism · diaspora',
    colour: 'black',
    emoji: '✈',
  },
];
---

<section aria-labelledby="life-stage-heading" class="tiles">
  <h2 id="life-stage-heading" class="sr-only">Browse by life stage</h2>
  <div class="tiles__grid">
    {
      tiles.map((tile) => (
        <a href={tile.href} class={`tile tile--${tile.colour}`}>
          <span class="tile__icon" aria-hidden="true">
            {tile.emoji}
          </span>
          <span class="tile__label">{tile.label}</span>
          <span class="tile__descriptor">{tile.descriptor}</span>
        </a>
      ))
    }
  </div>
</section>

<style>
  .tiles {
    padding: 2.5rem 1.25rem;
    max-width: 72rem;
    margin: 0 auto;
  }
  .tiles__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 40rem) {
    .tiles__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 64rem) {
    .tiles__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .tile {
    display: block;
    background: #fff;
    border: 1px solid #e5e0d6;
    border-radius: 3px;
    padding: 1.25rem 1rem;
    text-decoration: none;
    color: #2b2e34;
    min-height: 44px;
    transition:
      transform 150ms ease-out,
      box-shadow 150ms ease-out;
  }
  @media (prefers-reduced-motion: reduce) {
    .tile {
      transition: none;
    }
  }
  .tile:hover,
  .tile:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
  }
  .tile:focus-visible {
    outline: 3px solid #fcd116;
    outline-offset: 2px;
  }
  .tile--green {
    border-left: 4px solid #005a35;
  }
  .tile--red {
    border-left: 4px solid #820b18;
  }
  .tile--gold {
    border-left: 4px solid #e0b912;
  }
  .tile--black {
    border-left: 4px solid #000;
  }
  .tile__icon {
    display: block;
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .tile__label {
    display: block;
    font-family: Georgia, serif;
    font-weight: 600;
    font-size: 1.125rem;
    margin-bottom: 0.25rem;
  }
  .tile__descriptor {
    display: block;
    font-size: 0.8125rem;
    color: #5b5f68;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
