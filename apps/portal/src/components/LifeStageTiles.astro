---
/**
 * Life-stage tiles — the primary category nav on the homepage.
 *
 * Each tile carries a per-stage Kente thread (vertical on the left) that
 * shimmers on hover, a distinctive monochrome mark (no emoji), and an
 * editorial serif label.
 */
interface Tile {
  href: string;
  label: string;
  descriptor: string;
  colour: 'green' | 'red' | 'gold' | 'ink';
  mark: 'live' | 'work' | 'business' | 'visit';
}

const tiles: ReadonlyArray<Tile> = [
  {
    href: '/services/live/',
    label: 'Live',
    descriptor: 'Identity · health · housing · family',
    colour: 'green',
    mark: 'live',
  },
  {
    href: '/services/work/',
    label: 'Work',
    descriptor: 'Tax · pensions · professional permits',
    colour: 'red',
    mark: 'work',
  },
  {
    href: '/services/business/',
    label: 'Do business',
    descriptor: 'Register · license · trade · grow',
    colour: 'gold',
    mark: 'business',
  },
  {
    href: '/services/visit/',
    label: 'Visit',
    descriptor: 'Passports · visas · diaspora',
    colour: 'ink',
    mark: 'visit',
  },
];
---

<section aria-labelledby="life-stage-heading" class="tiles">
  <div class="tiles__inner">
    <header class="tiles__head">
      <p class="tiles__eyebrow">Find what you need</p>
      <h2 id="life-stage-heading" class="tiles__title">Start with a moment of your life.</h2>
    </header>
    <div class="tiles__grid">
      {
        tiles.map((tile) => (
          <a href={tile.href} class={`tile tile--${tile.colour}`}>
            <span class="tile__thread" aria-hidden="true" />
            <span class="tile__mark" aria-hidden="true">
              {tile.mark === 'live' && (
                <svg viewBox="0 0 32 32" width="28" height="28" fill="none">
                  <circle cx="16" cy="12" r="5" stroke="currentColor" stroke-width="1.5" />
                  <path
                    d="M6 28 Q 6 18 16 18 T 26 28"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                  />
                </svg>
              )}
              {tile.mark === 'work' && (
                <svg viewBox="0 0 32 32" width="28" height="28" fill="none">
                  <path
                    d="M6 10 L16 4 L26 10 L26 26 L18 26 L18 18 L14 18 L14 26 L6 26 Z"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linejoin="round"
                  />
                </svg>
              )}
              {tile.mark === 'business' && (
                <svg viewBox="0 0 32 32" width="28" height="28" fill="none">
                  <path
                    d="M6 26 L6 12 L13 12 L13 6 L19 6 L19 14 L26 14 L26 26 Z"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linejoin="round"
                  />
                  <path
                    d="M11 26 L11 20 L15 20 L15 26 M21 26 L21 20 L25 20 L25 26"
                    stroke="currentColor"
                    stroke-width="1.5"
                  />
                </svg>
              )}
              {tile.mark === 'visit' && (
                <svg viewBox="0 0 32 32" width="28" height="28" fill="none">
                  <path
                    d="M4 18 L26 6 L24 18 L16 16 L12 22 L11 18 L4 18 Z"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linejoin="round"
                  />
                </svg>
              )}
            </span>
            <div class="tile__body">
              <div class="tile__label">{tile.label}</div>
              <div class="tile__descriptor">{tile.descriptor}</div>
            </div>
            <span class="tile__arrow" aria-hidden="true">
              <svg viewBox="0 0 16 16" width="16" height="16" fill="none">
                <path
                  d="M4 8 h8 M8 4 l4 4 -4 4"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .tiles {
    background: #faf7f2;
    padding: 0;
  }
  .tiles__inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5.5rem) clamp(1.25rem, 4vw, 3rem);
  }
  .tiles__head {
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
    max-width: 44ch;
  }
  .tiles__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    color: #820b18;
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 0.75rem;
  }
  .tiles__title {
    font-family: Georgia, 'Playfair Display', serif;
    font-size: clamp(1.625rem, 3vw, 2.25rem);
    line-height: 1.1;
    color: #002818;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .tiles__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.875rem;
  }
  @media (min-width: 40rem) {
    .tiles__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 64rem) {
    .tiles__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .tile {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 1.375rem 1.25rem 1.375rem 1.75rem;
    background: #fffef9;
    border: 1px solid #e5e0d6;
    border-radius: 2px;
    text-decoration: none;
    color: #1a1a1a;
    min-height: 88px;
    overflow: hidden;
    transition:
      transform 280ms cubic-bezier(0.2, 0.9, 0.3, 1),
      box-shadow 280ms cubic-bezier(0.2, 0.9, 0.3, 1),
      border-color 280ms ease;
  }
  .tile:hover,
  .tile:focus-visible {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0, 40, 24, 0.12);
    border-color: rgba(0, 90, 53, 0.3);
  }
  .tile:focus-visible {
    outline: 3px solid #fcd116;
    outline-offset: 3px;
  }

  /* The Kente thread — a vertical multi-colour strip on the left of every tile.
     Each colour variant positions the same weave pattern but at a different
     vertical offset so the "dominant" thread differs per life stage. */
  .tile__thread {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 6px;
    background: repeating-linear-gradient(
      180deg,
      #006b3f 0 18px,
      #fcd116 18px 26px,
      #ce1126 26px 44px,
      #0b0b0f 44px 52px
    );
    opacity: 0.9;
    transition: width 280ms cubic-bezier(0.2, 0.9, 0.3, 1);
  }
  .tile:hover .tile__thread,
  .tile:focus-visible .tile__thread {
    width: 10px;
  }
  .tile--green .tile__thread {
    background-position: 0 0;
  }
  .tile--red .tile__thread {
    background-position: 0 -22px;
  }
  .tile--gold .tile__thread {
    background-position: 0 -44px;
  }
  .tile--ink .tile__thread {
    background-position: 0 -66px;
  }

  .tile__mark {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #faf7f2;
    border: 1px solid #e5e0d6;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition:
      background 240ms ease,
      border-color 240ms ease,
      color 240ms ease;
  }
  .tile--green .tile__mark {
    color: #004527;
  }
  .tile--red .tile__mark {
    color: #820b18;
  }
  .tile--gold .tile__mark {
    color: #8a7008;
  }
  .tile--ink .tile__mark {
    color: #1a1a1a;
  }
  .tile:hover .tile__mark,
  .tile:focus-visible .tile__mark {
    background: #fff;
    border-color: currentColor;
  }

  .tile__body {
    min-width: 0;
  }
  .tile__label {
    font-family: Georgia, 'Playfair Display', serif;
    font-weight: 700;
    font-size: 1.125rem;
    line-height: 1.1;
    margin-bottom: 0.2rem;
    color: #002818;
    letter-spacing: -0.005em;
  }
  .tile__descriptor {
    font-size: 0.8125rem;
    color: #5b5f68;
    line-height: 1.35;
  }

  .tile__arrow {
    color: #5b5f68;
    transition:
      color 240ms ease,
      transform 280ms cubic-bezier(0.2, 0.9, 0.3, 1);
    display: inline-flex;
  }
  .tile:hover .tile__arrow,
  .tile:focus-visible .tile__arrow {
    color: #004527;
    transform: translate(2px, -2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .tile,
    .tile__thread,
    .tile__mark,
    .tile__arrow {
      transition: none;
    }
    .tile:hover,
    .tile:focus-visible {
      transform: none;
    }
  }
</style>
