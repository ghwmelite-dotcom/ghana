---
/**
 * Ministries marquee — the 21 ministries scrolling slowly in one continuous
 * ribbon. Each name is a link. Pauses on hover. Respects reduced motion
 * (static staggered grid fallback instead of animated scroll).
 */
import { getCollection, type CollectionEntry } from 'astro:content';

const ministries: CollectionEntry<'ministries'>[] = (await getCollection('ministries')).sort(
  (a: CollectionEntry<'ministries'>, b: CollectionEntry<'ministries'>) =>
    a.data.name.localeCompare(b.data.name),
);

// Duplicate once so the CSS translate-50% loop appears seamless.
const doubled = [...ministries, ...ministries];
---

<section class="marquee" aria-labelledby="marquee-heading">
  <div class="marquee__inner">
    <header class="marquee__head">
      <p class="marquee__eyebrow">The 21 ministries</p>
      <h2 id="marquee-heading" class="marquee__title">Every arm of government, one directory.</h2>
    </header>
  </div>
  <div class="marquee__track">
    {
      doubled.map((m, i) => (
        <a
          href={`/ministries/${m.slug}/`}
          class="marquee__item"
          aria-hidden={i >= ministries.length ? 'true' : undefined}
          tabindex={i >= ministries.length ? -1 : undefined}
        >
          <span class="marquee__dot" aria-hidden="true" />
          <span class="marquee__name">{m.data.name.replace(/^Ministry of (the )?/, '')}</span>
        </a>
      ))
    }
  </div>
</section>

<style>
  .marquee {
    background: linear-gradient(180deg, #001008 0%, #002818 100%);
    color: #fffef9;
    position: relative;
    overflow: hidden;
    padding: clamp(3rem, 5vw, 4.5rem) 0;
    border-top: 1px solid #004527;
  }
  .marquee::before,
  .marquee::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 3px;
    background: repeating-linear-gradient(
      90deg,
      #006b3f 0 18px,
      #fcd116 18px 26px,
      #ce1126 26px 44px,
      #0b0b0f 44px 52px
    );
    opacity: 0.85;
  }
  .marquee::before {
    top: 0;
  }
  .marquee::after {
    bottom: 0;
  }

  .marquee__inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 3rem) clamp(1.75rem, 3vw, 2.5rem);
  }
  .marquee__head {
    max-width: 44ch;
  }
  .marquee__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    color: #fcd116;
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 0.75rem;
  }
  .marquee__title {
    font-family: Georgia, 'Playfair Display', serif;
    font-size: clamp(1.625rem, 3vw, 2.25rem);
    line-height: 1.1;
    color: #fffef9;
    margin: 0;
    letter-spacing: -0.01em;
  }

  /* The scrolling track. `doubled` array + translateX(-50%) gives a
     seamless infinite loop. Hover pauses; reduced-motion disables entirely. */
  .marquee__track {
    display: flex;
    gap: clamp(1.5rem, 3vw, 2.5rem);
    width: max-content;
    align-items: center;
    animation: marquee 60s linear infinite;
    will-change: transform;
    padding: 0.75rem 0;
  }
  .marquee__track:hover,
  .marquee__track:focus-within {
    animation-play-state: paused;
  }
  @keyframes marquee {
    from {
      transform: translate3d(0, 0, 0);
    }
    to {
      transform: translate3d(-50%, 0, 0);
    }
  }

  .marquee__item {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: rgba(255, 253, 245, 0.82);
    font-family: Georgia, serif;
    font-size: 1.0625rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    padding: 0.5rem 0;
    transition: color 200ms ease;
  }
  .marquee__item:hover,
  .marquee__item:focus-visible {
    color: #fcd116;
  }
  .marquee__item:focus-visible {
    outline: 2px solid #fcd116;
    outline-offset: 4px;
    border-radius: 2px;
  }
  .marquee__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #fcd116;
    flex-shrink: 0;
    opacity: 0.55;
    transition:
      opacity 200ms ease,
      transform 200ms ease;
  }
  .marquee__item:hover .marquee__dot,
  .marquee__item:focus-visible .marquee__dot {
    opacity: 1;
    transform: scale(1.4);
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee__track {
      animation: none;
      flex-wrap: wrap;
      width: auto;
      max-width: 80rem;
      margin: 0 auto;
      padding-left: clamp(1.25rem, 4vw, 3rem);
      padding-right: clamp(1.25rem, 4vw, 3rem);
      justify-content: flex-start;
    }
  }
</style>
