---
/**
 * Ministries quick-access — replaces the old scrolling marquee. Static grid
 * of links, gov.rw-calm; matches the Footer's institutional tone.
 */
import { getCollection, type CollectionEntry } from 'astro:content';

const ministries: CollectionEntry<'ministries'>[] = (await getCollection('ministries')).sort(
  (a: CollectionEntry<'ministries'>, b: CollectionEntry<'ministries'>) =>
    a.data.name.localeCompare(b.data.name),
);

const short = (name: string) => name.replace(/^Ministry of (the )?/, '');
---

<section class="mins" aria-labelledby="mins-heading">
  <div class="mins__inner">
    <header class="mins__head" data-reveal>
      <div>
        <p class="mins__eyebrow">
          <span class="eyebrow-star" aria-hidden="true"></span>
          The 21 ministries
        </p>
        <h2 id="mins-heading" class="mins__title">Every arm of government, one directory.</h2>
      </div>
      <a href="/ministries/" class="mins__more">
        All ministries
        <svg viewBox="0 0 16 16" width="12" height="12" fill="none" aria-hidden="true">
          <path
            d="M3 8 h10 M9 4 l4 4 -4 4"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
    </header>
    <ul class="mins__list" data-reveal>
      {
        ministries.map((m) => (
          <li>
            <a href={`/ministries/${m.slug}/`} class="mins__item">
              <span class="mins__item-dot" aria-hidden="true" />
              <span class="mins__item-label">{short(m.data.name)}</span>
              <span class="mins__item-arrow" aria-hidden="true">
                →
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .mins {
    background: #ffffff;
    padding: clamp(3rem, 6vw, 5rem) clamp(1.25rem, 4vw, 3rem);
    border-bottom: 1px solid #edeae2;
  }
  .mins__inner {
    max-width: 80rem;
    margin: 0 auto;
  }
  .mins__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: clamp(1.75rem, 3vw, 2.5rem);
  }
  .mins__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: #005a35;
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .mins__title {
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    font-weight: 700;
    color: #0a0f1f;
    margin: 0;
    letter-spacing: -0.015em;
  }
  .mins__more {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #005a35;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
  }
  .mins__more:hover,
  .mins__more:focus-visible {
    border-bottom-color: #005a35;
  }

  .mins__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0;
    border-top: 1px solid #edeae2;
    border-left: 1px solid #edeae2;
  }
  .mins__item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.95rem 1rem;
    text-decoration: none;
    color: #111827;
    font-size: 0.9375rem;
    border-right: 1px solid #edeae2;
    border-bottom: 1px solid #edeae2;
    min-height: 48px;
    position: relative;
    overflow: hidden;
    transition:
      background 200ms ease,
      color 200ms ease,
      padding-left 240ms cubic-bezier(0.2, 0.9, 0.3, 1);
  }
  .mins__item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 0;
    background: linear-gradient(180deg, #006b3f 0%, #fcd116 50%, #ce1126 100%);
    transition: width 280ms cubic-bezier(0.2, 0.9, 0.3, 1);
  }
  .mins__item:hover,
  .mins__item:focus-visible {
    background: #fff;
    color: #005a35;
    padding-left: 1.375rem;
  }
  .mins__item:hover::before,
  .mins__item:focus-visible::before {
    width: 3px;
  }
  .mins__item:focus-visible {
    outline: 3px solid #fcd116;
    outline-offset: -3px;
  }
  .mins__item-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #fcd116;
    flex-shrink: 0;
    transition: transform 200ms ease;
  }
  .mins__item:hover .mins__item-dot,
  .mins__item:focus-visible .mins__item-dot {
    transform: scale(1.4);
  }
  .mins__item-label {
    flex: 1;
  }
  .mins__item-arrow {
    color: #005a35;
    font-size: 0.9375rem;
    opacity: 0;
    transform: translateX(-4px);
    transition:
      opacity 220ms ease,
      transform 220ms cubic-bezier(0.2, 0.9, 0.3, 1);
  }
  .mins__item:hover .mins__item-arrow,
  .mins__item:focus-visible .mins__item-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .mins__item,
    .mins__item::before,
    .mins__item-dot,
    .mins__item-arrow {
      transition: none;
    }
    .mins__item:hover,
    .mins__item:focus-visible {
      padding-left: 1rem;
    }
    .mins__item:hover .mins__item-dot {
      transform: none;
    }
  }
</style>
