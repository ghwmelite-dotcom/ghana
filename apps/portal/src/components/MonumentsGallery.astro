---
/**
 * Monuments & heritage — editorial photograph grid using our Nkrumah
 * Memorial Park pool. Distinctly Ghanaian visual moment that breaks up
 * the rhythm of service and news cards.
 */
import { Image } from 'astro:assets';
import nkrumahStatue from '../assets/photos/nkrumah-statue.png';
import nkrumahMausoleum from '../assets/photos/nkrumah-mausoleum.png';
import nkrumahPresidents from '../assets/photos/nkrumah-presidents-mural.png';
import nkrumahBlackStar from '../assets/photos/nkrumah-black-star.png';
---

<section class="monuments" aria-labelledby="monuments-heading">
  <div class="monuments__inner">
    <header class="monuments__head">
      <p class="monuments__eyebrow">Heritage</p>
      <h2 id="monuments-heading" class="monuments__title">Monuments to a nation.</h2>
      <p class="monuments__lede">
        Kwame Nkrumah Memorial Park, Black Star Square, and the mausoleum of the founder of modern
        Ghana — a pilgrimage for every citizen and returning diaspora Ghanaian.
      </p>
    </header>

    <div class="monuments__grid">
      <figure class="monuments__item monuments__item--lead">
        <Image
          src={nkrumahStatue}
          alt="The statue of Kwame Nkrumah, arm outstretched, at the Memorial Park."
          widths={[640, 960, 1280]}
          sizes="(min-width: 64rem) 620px, 100vw"
          quality={78}
        />
        <figcaption>
          <span class="monuments__tag">Memorial Park</span>
          <span class="monuments__caption-title">Founder &amp; First Prime Minister</span>
          <span class="monuments__caption-sub">Kwame Nkrumah, 1909 – 1972</span>
        </figcaption>
      </figure>
      <figure class="monuments__item">
        <Image
          src={nkrumahMausoleum}
          alt="The white stone mausoleum of Kwame Nkrumah, with bronze statues flanking the entrance."
          widths={[480, 720]}
          sizes="(min-width: 64rem) 300px, 100vw"
          quality={78}
        />
        <figcaption>
          <span class="monuments__tag">Mausoleum</span>
          <span class="monuments__caption-title">Final resting place</span>
        </figcaption>
      </figure>
      <figure class="monuments__item">
        <Image
          src={nkrumahPresidents}
          alt="Portraits of past Presidents of Ghana at the Memorial Park."
          widths={[480, 720]}
          sizes="(min-width: 64rem) 300px, 100vw"
          quality={78}
        />
        <figcaption>
          <span class="monuments__tag">Legacy</span>
          <span class="monuments__caption-title">Presidents of Ghana</span>
        </figcaption>
      </figure>
      <figure class="monuments__item monuments__item--wide">
        <Image
          src={nkrumahBlackStar}
          alt="The Black Star monument at the Nkrumah Memorial Park."
          widths={[640, 960, 1280]}
          sizes="(min-width: 64rem) 620px, 100vw"
          quality={78}
        />
        <figcaption>
          <span class="monuments__tag">Black Star</span>
          <span class="monuments__caption-title">Emblem of African emancipation</span>
        </figcaption>
      </figure>
    </div>
  </div>
</section>

<style>
  .monuments {
    background: #f7f7f5;
    padding: clamp(3rem, 6vw, 5rem) clamp(1.25rem, 4vw, 3rem);
    border-bottom: 1px solid #edeae2;
  }
  .monuments__inner {
    max-width: 80rem;
    margin: 0 auto;
  }
  .monuments__head {
    max-width: 52ch;
    margin-bottom: clamp(1.75rem, 3vw, 2.5rem);
  }
  .monuments__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: #005a35;
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .monuments__title {
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    font-weight: 700;
    color: #0a0f1f;
    margin: 0 0 0.75rem;
    letter-spacing: -0.015em;
  }
  .monuments__lede {
    font-size: 1rem;
    color: #384251;
    line-height: 1.55;
    margin: 0;
    max-width: 58ch;
  }

  .monuments__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 48rem) {
    .monuments__grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: minmax(240px, auto);
    }
    .monuments__item--lead {
      grid-column: span 2;
    }
    .monuments__item--wide {
      grid-column: span 2;
    }
  }
  @media (min-width: 64rem) {
    .monuments__grid {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 320px;
    }
    .monuments__item--lead {
      grid-column: span 2;
      grid-row: span 2;
    }
    .monuments__item {
      grid-column: span 1;
    }
    .monuments__item--wide {
      grid-column: span 2;
      grid-row: span 1;
    }
  }

  .monuments__item {
    position: relative;
    margin: 0;
    overflow: hidden;
    border-radius: 4px;
    background: #e5e0d6;
    box-shadow: 0 4px 20px -8px rgba(0, 0, 0, 0.12);
  }
  .monuments__item :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 800ms cubic-bezier(0.2, 0.9, 0.3, 1);
  }
  .monuments__item:hover :global(img) {
    transform: scale(1.03);
  }
  .monuments__item::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(10, 15, 31, 0.85) 100%);
    pointer-events: none;
  }
  .monuments__item figcaption {
    position: absolute;
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
    color: #fff;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .monuments__tag {
    font-size: 0.625rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #fcd116;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  .monuments__caption-title {
    font-size: clamp(0.9375rem, 1.1vw, 1.0625rem);
    font-weight: 600;
    line-height: 1.25;
  }
  .monuments__caption-sub {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.75);
    font-style: italic;
  }

  @media (prefers-reduced-motion: reduce) {
    .monuments__item :global(img) {
      transition: none;
    }
    .monuments__item:hover :global(img) {
      transform: none;
    }
  }
</style>
