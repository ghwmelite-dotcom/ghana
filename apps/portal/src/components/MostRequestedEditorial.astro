---
/**
 * Most-requested services — rendered as an editorial numbered list rather
 * than a simple band. Large gold display numerals, thin dividers, hover states
 * that reveal a gold ink underline per row.
 */
interface Item {
  label: string;
  href: string;
  /** Short ministry / agency attribution shown on hover + mobile. */
  agency?: string;
}

const items: ReadonlyArray<Item> = [
  {
    label: 'Renew your passport',
    href: '/services/renew-passport/',
    agency: 'Ghana Immigration Service',
  },
  {
    label: 'Apply for a Ghana Card',
    href: '/services/apply-ghana-card/',
    agency: 'National Identification Authority',
  },
  {
    label: 'File your income tax return',
    href: '/services/file-income-tax/',
    agency: 'Ghana Revenue Authority',
  },
  {
    label: 'Register a business',
    href: '/services/register-business/',
    agency: 'Registrar of Companies',
  },
  {
    label: "Renew your driver's licence",
    href: '/services/renew-drivers-licence/',
    agency: 'DVLA',
  },
  {
    label: 'Apply for a birth certificate',
    href: '/services/apply-birth-certificate/',
    agency: 'Births and Deaths Registry',
  },
  {
    label: 'Apply for dual citizenship',
    href: '/services/apply-dual-citizenship/',
    agency: 'Ministry of the Interior',
  },
  { label: 'Register for VAT', href: '/services/register-vat/', agency: 'Ghana Revenue Authority' },
];
---

<section class="requested" aria-labelledby="requested-heading">
  <div class="requested__inner">
    <header class="requested__head">
      <p class="requested__eyebrow">Most requested this month</p>
      <h2 id="requested-heading" class="requested__title">What Ghanaians are looking for.</h2>
    </header>
    <ol class="requested__list">
      {
        items.map((item, i) => (
          <li>
            <a href={item.href} class="row">
              <span class="row__num" aria-hidden="true">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class="row__label">{item.label}</span>
              {item.agency && <span class="row__agency">{item.agency}</span>}
              <span class="row__arrow" aria-hidden="true">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="none">
                  <path
                    d="M3 8 h10 M9 4 l4 4 -4 4"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </a>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .requested {
    background: #fffef9;
    border-top: 1px solid #e5e0d6;
  }
  .requested__inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) clamp(1.25rem, 4vw, 3rem);
  }
  .requested__head {
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
    max-width: 44ch;
  }
  .requested__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    color: #820b18;
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 0.75rem;
  }
  .requested__title {
    font-family: Georgia, 'Playfair Display', serif;
    font-size: clamp(1.625rem, 3vw, 2.25rem);
    line-height: 1.1;
    color: #002818;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .requested__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    border-top: 1px solid #e5e0d6;
  }
  @media (min-width: 48rem) {
    .requested__list {
      grid-template-columns: 1fr 1fr;
      column-gap: 3rem;
    }
  }

  .row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: 1rem;
    padding: 1.125rem 0 1.125rem 0.25rem;
    text-decoration: none;
    color: #1a1a1a;
    border-bottom: 1px solid #e5e0d6;
    position: relative;
    min-height: 44px;
    transition: padding 220ms cubic-bezier(0.2, 0.9, 0.3, 1);
  }
  .row::before {
    content: '';
    position: absolute;
    left: 0;
    bottom: -1px;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, #006b3f 0%, #fcd116 60%, #ce1126 100%);
    transition: width 320ms cubic-bezier(0.2, 0.9, 0.3, 1);
  }
  .row:hover,
  .row:focus-visible {
    padding-left: 0.75rem;
  }
  .row:hover::before,
  .row:focus-visible::before {
    width: 100%;
  }
  .row:focus-visible {
    outline: 3px solid #fcd116;
    outline-offset: 2px;
  }

  .row__num {
    font-family: Georgia, 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #b8960c;
    font-variant-numeric: tabular-nums;
    min-width: 2ch;
  }
  .row__label {
    font-family: Georgia, serif;
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.3;
    color: #002818;
    grid-column: 2;
  }
  .row__agency {
    display: none;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: #5b5f68;
    text-transform: uppercase;
    font-weight: 600;
    grid-column: 2;
    margin-top: 0.25rem;
  }
  .row:hover .row__agency,
  .row:focus-visible .row__agency {
    display: block;
  }
  .row__arrow {
    color: #5b5f68;
    transition:
      color 200ms ease,
      transform 260ms cubic-bezier(0.2, 0.9, 0.3, 1);
    display: inline-flex;
  }
  .row:hover .row__arrow,
  .row:focus-visible .row__arrow {
    color: #004527;
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    .row,
    .row::before,
    .row__arrow {
      transition: none;
    }
  }
</style>
