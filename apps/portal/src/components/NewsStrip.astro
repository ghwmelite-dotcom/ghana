---
/**
 * Homepage news preview — most-recent news entries up to `limit`. Falls back
 * gracefully to a placeholder if the news collection is empty.
 */
import { getCollection, type CollectionEntry } from 'astro:content';

interface Props {
  limit?: number;
}
const { limit = 4 } = Astro.props;
const news = (await getCollection('news'))
  .sort(
    (a: CollectionEntry<'news'>, b: CollectionEntry<'news'>) =>
      b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
  )
  .slice(0, limit);

const formatter = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
---

<section aria-labelledby="news-strip-heading" class="news-strip">
  <div class="news-strip__head">
    <h2 id="news-strip-heading">Latest from government</h2>
    <a href="/news/" class="news-strip__all">All news →</a>
  </div>
  {
    news.length === 0 ? (
      <p class="news-strip__empty">News articles land here as they're published.</p>
    ) : (
      <ul class="news-strip__grid">
        {news.map((n: CollectionEntry<'news'>) => (
          <li>
            <a href={`/news/${n.data.publishedAt.getFullYear()}/${n.data.slug}/`} class="card">
              <p class="card__eyebrow">
                {n.data.ministry.toUpperCase()} · {formatter.format(n.data.publishedAt)}
              </p>
              <h3>{n.data.title}</h3>
              <p class="card__lede">{n.data.lede}</p>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</section>

<style>
  .news-strip {
    padding: 2.5rem 1.25rem;
    max-width: 72rem;
    margin: 0 auto;
  }
  .news-strip__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1rem;
  }
  h2 {
    font-family: Georgia, serif;
    font-size: 1.5rem;
    margin: 0;
    color: #004527;
  }
  .news-strip__all {
    color: #004527;
    text-decoration: none;
    font-size: 0.875rem;
  }
  .news-strip__all:hover {
    text-decoration: underline;
  }
  .news-strip__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 48rem) {
    .news-strip__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .card {
    display: block;
    background: #fff;
    border: 1px solid #e5e0d6;
    border-radius: 3px;
    padding: 1rem;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }
  .card:hover {
    border-color: #005a35;
  }
  .card__eyebrow {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    color: #820b18;
    margin: 0 0 0.5rem;
  }
  h3 {
    font-family: Georgia, serif;
    font-size: 1rem;
    line-height: 1.25;
    margin: 0 0 0.375rem;
  }
  .card__lede {
    font-size: 0.8125rem;
    color: #5b5f68;
    margin: 0;
    line-height: 1.4;
  }
  .news-strip__empty {
    padding: 1.5rem;
    text-align: center;
    color: #5b5f68;
    background: #fff;
    border: 1px dashed #e5e0d6;
    border-radius: 3px;
  }
</style>
