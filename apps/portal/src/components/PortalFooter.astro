---
/**
 * PortalFooter — gov.rw-aligned multi-column footer with a dark ink ground,
 * five grouped link columns, coat-of-arms crest, social icons row, and a
 * fine copyright strip at the bottom.
 *
 * Replaces the default @gh/gh-ds/Footer on portal pages. The design-system
 * footer stays in place for any future consumers; portal just opts out.
 */
import { Image } from 'astro:assets';
import coatOfArms from '../assets/photos/coat-of-arms.png';

interface FooterLink {
  href: string;
  label: string;
  external?: boolean;
}

interface FooterColumn {
  heading: string;
  links: ReadonlyArray<FooterLink>;
}

const columns: ReadonlyArray<FooterColumn> = [
  {
    heading: 'Services',
    links: [
      { href: '/services/live/', label: 'Live in Ghana' },
      { href: '/services/work/', label: 'Work in Ghana' },
      { href: '/services/business/', label: 'Do business in Ghana' },
      { href: '/services/visit/', label: 'Visit Ghana' },
      { href: '/services/a-z/', label: 'A–Z of services' },
      { href: '/services/diaspora/', label: 'For the diaspora' },
    ],
  },
  {
    heading: 'Government',
    links: [
      { href: '/ministries/', label: 'Ministries' },
      { href: '/news/', label: 'News &amp; announcements' },
      { href: '/about/', label: 'About gov.gh' },
      { href: '/accessibility/', label: 'Accessibility' },
      { href: '/privacy/', label: 'Privacy' },
      { href: '/search/', label: 'Search' },
    ],
  },
  {
    heading: 'Agencies',
    links: [
      { href: 'https://nia.gov.gh', label: 'NIA — National ID', external: true },
      { href: 'https://gra.gov.gh', label: 'GRA — Revenue', external: true },
      { href: 'https://dvla.gov.gh', label: 'DVLA — Driving', external: true },
      { href: 'https://passports.gov.gh', label: 'GIS — Immigration', external: true },
      { href: 'https://ssnit.org.gh', label: 'SSNIT — Social Security', external: true },
      { href: 'https://nhis.gov.gh', label: 'NHIS — Health Insurance', external: true },
    ],
  },
  {
    heading: 'Publications',
    links: [
      { href: 'https://mofep.gov.gh', label: 'Budget statements', external: true },
      { href: '/news/feed.xml', label: 'News RSS feed' },
      { href: 'https://parliament.gh', label: 'Hansard (Parliament)', external: true },
      { href: '/sitemap-index.xml', label: 'Sitemap' },
    ],
  },
  {
    heading: 'Connect',
    links: [
      { href: '/contact/', label: 'Contact us' },
      { href: 'mailto:feedback@gov.gh', label: 'Send feedback' },
      { href: 'mailto:rti@information.gov.gh', label: 'Right to Information' },
      { href: '/.well-known/security.txt', label: 'Report a security issue' },
      { href: 'tel:+233800100280', label: 'Anti-Corruption Hotline' },
    ],
  },
];

const socials: ReadonlyArray<{
  href: string;
  label: string;
  icon: 'x' | 'fb' | 'yt' | 'ig' | 'li' | 'wa';
}> = [
  { href: 'https://x.com/government_gh', label: 'Government of Ghana on X (Twitter)', icon: 'x' },
  {
    href: 'https://www.facebook.com/government.gh',
    label: 'Government of Ghana on Facebook',
    icon: 'fb',
  },
  {
    href: 'https://www.youtube.com/@governmentofghana',
    label: 'Government of Ghana on YouTube',
    icon: 'yt',
  },
  {
    href: 'https://www.instagram.com/government.gh',
    label: 'Government of Ghana on Instagram',
    icon: 'ig',
  },
  {
    href: 'https://www.linkedin.com/company/government-of-ghana',
    label: 'Government of Ghana on LinkedIn',
    icon: 'li',
  },
];

const year = new Date().getFullYear();
---

<footer class="footer" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Site footer</h2>

  <div class="footer__top">
    <div class="footer__inner">
      <div class="footer__brand">
        <figure class="footer__crest" aria-hidden="true">
          <Image src={coatOfArms} alt="" widths={[120, 180]} sizes="72px" quality={90} />
        </figure>
        <div>
          <p class="footer__brand-label">Republic of Ghana</p>
          <p class="footer__brand-name">gov.gh</p>
          <p class="footer__brand-sub">Freedom and Justice · Since 1957</p>
        </div>
      </div>

      <nav class="footer__nav" aria-label="Footer">
        {
          columns.map((col) => (
            <div class="footer__col">
              <h3 class="footer__col-heading">{col.heading}</h3>
              <ul>
                {col.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      rel={link.external ? 'noopener external' : undefined}
                      target={link.external ? '_blank' : undefined}
                      set:html={link.label}
                    />
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </nav>
    </div>
  </div>

  <div class="footer__mid">
    <div class="footer__inner footer__mid-inner">
      <p class="footer__attribution">
        A service of the
        <a href="https://ohcs.gov.gh" rel="external" target="_blank"
          >Office of the Head of Civil Service</a
        >, under the
        <a href="https://presidency.gov.gh" rel="external" target="_blank"
          >Office of the President, Republic of Ghana</a
        >.
      </p>
      <ul class="footer__social" aria-label="Follow the Government of Ghana">
        {
          socials.map((s) => (
            <li>
              <a href={s.href} aria-label={s.label} rel="noopener external" target="_blank">
                {s.icon === 'x' && (
                  <svg
                    viewBox="0 0 20 20"
                    width="18"
                    height="18"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M14.72 2h2.68l-5.85 6.68L18.5 18h-5.4l-4.23-5.53L3.78 18H1.1l6.25-7.14L1 2h5.54l3.82 5.05L14.72 2Zm-.94 14.4h1.48L6.3 3.52H4.72l9.06 12.88Z" />
                  </svg>
                )}
                {s.icon === 'fb' && (
                  <svg
                    viewBox="0 0 20 20"
                    width="18"
                    height="18"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M10 0C4.48 0 0 4.48 0 10c0 4.99 3.66 9.12 8.44 9.88v-6.99H5.9V10h2.54V7.8c0-2.51 1.49-3.9 3.78-3.9 1.09 0 2.24.2 2.24.2v2.47h-1.26c-1.24 0-1.63.77-1.63 1.56V10h2.78l-.44 2.89H11.56v6.99C16.34 19.12 20 14.99 20 10c0-5.52-4.48-10-10-10Z" />
                  </svg>
                )}
                {s.icon === 'yt' && (
                  <svg
                    viewBox="0 0 20 20"
                    width="20"
                    height="20"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M19.58 5.19a2.49 2.49 0 0 0-1.75-1.75C16.28 3 10 3 10 3s-6.28 0-7.83.44A2.49 2.49 0 0 0 .42 5.19C0 6.74 0 10 0 10s0 3.26.42 4.81a2.49 2.49 0 0 0 1.75 1.75C3.72 17 10 17 10 17s6.28 0 7.83-.44a2.49 2.49 0 0 0 1.75-1.75C20 13.26 20 10 20 10s0-3.26-.42-4.81ZM8 13V7l5.2 3L8 13Z" />
                  </svg>
                )}
                {s.icon === 'ig' && (
                  <svg
                    viewBox="0 0 20 20"
                    width="18"
                    height="18"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.4"
                    aria-hidden="true"
                  >
                    <rect x="2.5" y="2.5" width="15" height="15" rx="4" />
                    <circle cx="10" cy="10" r="3.6" />
                    <circle cx="14.5" cy="5.5" r="0.9" fill="currentColor" />
                  </svg>
                )}
                {s.icon === 'li' && (
                  <svg
                    viewBox="0 0 20 20"
                    width="18"
                    height="18"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M17 1H3a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2ZM6.3 16.2H3.6V7.9h2.7v8.3ZM4.94 6.8a1.57 1.57 0 1 1 0-3.13 1.57 1.57 0 0 1 0 3.13ZM16.4 16.2h-2.7v-4.47c0-1.33-.48-2.24-1.66-2.24-.9 0-1.44.61-1.68 1.2-.09.21-.11.5-.11.79v4.72H7.55s.04-7.66 0-8.3h2.7v1.18c.36-.56 1-1.36 2.45-1.36 1.8 0 3.15 1.17 3.15 3.67v4.81Z" />
                  </svg>
                )}
                {s.icon === 'wa' && (
                  <svg
                    viewBox="0 0 20 20"
                    width="18"
                    height="18"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M10 0C4.52 0 .06 4.46.06 9.94c0 1.76.46 3.48 1.33 5L0 20l5.2-1.36a9.9 9.9 0 0 0 4.8 1.22h.01c5.48 0 9.94-4.46 9.94-9.94S15.48 0 10 0Zm0 18.18a8.23 8.23 0 0 1-4.2-1.15l-.3-.18-3.1.81.83-3.02-.2-.31a8.18 8.18 0 0 1-1.25-4.39A8.23 8.23 0 1 1 10 18.18Zm4.54-6.15c-.25-.13-1.47-.73-1.7-.81-.22-.08-.39-.13-.55.13-.17.25-.64.8-.78.97-.14.17-.29.19-.54.06-.25-.13-1.05-.39-2-1.23a7.4 7.4 0 0 1-1.37-1.7c-.14-.25-.02-.39.11-.51.11-.11.25-.29.37-.44.13-.14.17-.25.25-.42.08-.17.04-.31-.02-.44-.06-.13-.55-1.33-.76-1.82-.2-.48-.4-.42-.55-.42h-.47c-.17 0-.44.06-.67.31-.23.25-.88.86-.88 2.1 0 1.25.91 2.45 1.03 2.62.13.17 1.77 2.7 4.28 3.79 1.88.81 2.7.83 3.36.69.4-.08 1.24-.51 1.42-1 .17-.48.17-.9.12-1-.06-.09-.22-.15-.47-.27Z" />
                  </svg>
                )}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="footer__inner footer__bottom-inner">
      <p class="footer__copy">
        © {year} Republic of Ghana. Content licensed <a
          href="https://creativecommons.org/licenses/by/4.0/"
          rel="external"
          target="_blank">CC BY 4.0</a
        > unless noted.
      </p>
      <ul class="footer__legal">
        <li><a href="/accessibility/">Accessibility</a></li>
        <li><a href="/privacy/">Privacy</a></li>
        <li>
          <a href="https://github.com/ghwmelite-dotcom/ghana" rel="external" target="_blank"
            >Source code (MIT)</a
          >
        </li>
      </ul>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #0a0f1f;
    color: rgba(255, 255, 255, 0.82);
    position: relative;
    border-top: 3px solid transparent;
    border-image: linear-gradient(
        90deg,
        #006b3f 0%,
        #006b3f 33%,
        #fcd116 33%,
        #fcd116 66%,
        #ce1126 66%,
        #ce1126 100%
      )
      1;
  }

  .footer__inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 3rem);
  }

  /* Top: brand + 5 link columns. */
  .footer__top {
    padding: clamp(2.5rem, 5vw, 4rem) 0 clamp(1.75rem, 3vw, 2.5rem);
  }
  .footer__top .footer__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 3rem);
  }
  @media (min-width: 64rem) {
    .footer__top .footer__inner {
      grid-template-columns: minmax(0, 240px) minmax(0, 1fr);
      gap: clamp(3rem, 6vw, 5rem);
    }
  }

  .footer__brand {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }
  .footer__crest {
    margin: 0;
    width: 64px;
    flex-shrink: 0;
  }
  .footer__crest :global(img) {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 6px 16px rgba(0, 0, 0, 0.6));
  }
  .footer__brand-label {
    font-size: 0.625rem;
    letter-spacing: 0.25em;
    color: #fcd116;
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 0.125rem;
  }
  .footer__brand-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.25rem;
    letter-spacing: -0.01em;
  }
  .footer__brand-sub {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
    line-height: 1.4;
  }

  .footer__nav {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1.75rem 1.5rem;
  }
  .footer__col-heading {
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    color: #fcd116;
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 0.875rem;
  }
  .footer__col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .footer__col a {
    color: rgba(255, 255, 255, 0.78);
    text-decoration: none;
    font-size: 0.875rem;
    line-height: 1.45;
    transition: color 160ms ease;
    display: inline-block;
  }
  .footer__col a:hover,
  .footer__col a:focus-visible {
    color: #fcd116;
  }
  .footer__col a:focus-visible {
    outline: 2px solid #fcd116;
    outline-offset: 3px;
    border-radius: 2px;
  }

  /* Middle: OHCS attribution + social icons. */
  .footer__mid {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 1.5rem 0;
  }
  .footer__mid-inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }
  @media (min-width: 48rem) {
    .footer__mid-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
  .footer__attribution {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.5;
    margin: 0;
    max-width: 60ch;
  }
  .footer__attribution a {
    color: rgba(255, 255, 255, 0.9);
    text-decoration-color: rgba(252, 209, 22, 0.5);
  }
  .footer__attribution a:hover {
    color: #fcd116;
    text-decoration-color: #fcd116;
  }

  .footer__social {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .footer__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 4px;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition:
      color 160ms ease,
      border-color 160ms ease,
      background 160ms ease;
  }
  .footer__social a:hover,
  .footer__social a:focus-visible {
    color: #0a0f1f;
    background: #fcd116;
    border-color: #fcd116;
  }
  .footer__social a:focus-visible {
    outline: 2px solid #fcd116;
    outline-offset: 3px;
  }

  /* Bottom: copyright + minimal legal row. */
  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 1.25rem 0;
  }
  .footer__bottom-inner {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    align-items: flex-start;
  }
  @media (min-width: 48rem) {
    .footer__bottom-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
  .footer__copy {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
  }
  .footer__copy a {
    color: rgba(255, 255, 255, 0.8);
  }
  .footer__legal {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1.25rem;
  }
  .footer__legal a {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition: color 160ms ease;
  }
  .footer__legal a:hover,
  .footer__legal a:focus-visible {
    color: #fcd116;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
