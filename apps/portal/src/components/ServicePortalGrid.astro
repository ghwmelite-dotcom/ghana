---
/**
 * Service portal grid — three signature entry-point cards with rich hover,
 * gold ring on the icon chip, and staggered scroll-reveal.
 */
interface Portal {
  href: string;
  label: string;
  descriptor: string;
  icon: 'id' | 'business' | 'tax';
}

const portals: ReadonlyArray<Portal> = [
  {
    href: '/services/apply-ghana-card/',
    label: 'National ID (Ghana Card)',
    descriptor:
      'Apply for or renew your Ghana Card — also your Taxpayer Identification Number (TIN).',
    icon: 'id',
  },
  {
    href: '/services/register-business/',
    label: 'Business registration',
    descriptor:
      'Register a sole proprietorship, partnership, or limited company with the Registrar of Companies.',
    icon: 'business',
  },
  {
    href: '/services/file-income-tax/',
    label: 'Tax filing & payment',
    descriptor:
      'File annual income tax returns and pay via MoMo, bank, or through the GRA taxpayer portal.',
    icon: 'tax',
  },
];
---

<section class="portal" aria-labelledby="portal-heading">
  <div class="portal__inner">
    <header class="portal__head" data-reveal>
      <p class="portal__eyebrow">
        <span class="eyebrow-star" aria-hidden="true"></span>
        Most-used services
      </p>
      <h2 id="portal-heading" class="portal__title">Official service entry points.</h2>
      <p class="portal__lede">
        The three services Ghanaians use most often, with direct links to the responsible agency.
      </p>
    </header>

    <div class="portal__grid">
      {
        portals.map((p, i) => (
          <article class="pcard" data-reveal data-reveal-delay={String(i + 1)}>
            <span class="pcard__thread" aria-hidden="true" />
            <span class="pcard__icon" aria-hidden="true">
              <span class="pcard__icon-glow" />
              {p.icon === 'id' && (
                <svg viewBox="0 0 32 32" width="30" height="30" fill="none">
                  <rect
                    x="4"
                    y="8"
                    width="24"
                    height="18"
                    rx="2"
                    stroke="currentColor"
                    stroke-width="1.6"
                  />
                  <circle cx="11" cy="15" r="3" stroke="currentColor" stroke-width="1.6" />
                  <path
                    d="M7 22 Q 7 18 11 18 T 15 22"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                  />
                  <path
                    d="M18 14 h7 M18 17 h7 M18 20 h5"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                  />
                </svg>
              )}
              {p.icon === 'business' && (
                <svg viewBox="0 0 32 32" width="30" height="30" fill="none">
                  <path
                    d="M6 27 V13 L13 13 V8 L19 8 V15 L26 15 V27 Z"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linejoin="round"
                  />
                  <path
                    d="M10 27 v-4 h3 v4 M16 27 v-4 h3 v4 M22 27 v-4 h2 v4"
                    stroke="currentColor"
                    stroke-width="1.4"
                  />
                </svg>
              )}
              {p.icon === 'tax' && (
                <svg viewBox="0 0 32 32" width="30" height="30" fill="none">
                  <rect
                    x="6"
                    y="5"
                    width="20"
                    height="22"
                    rx="2"
                    stroke="currentColor"
                    stroke-width="1.6"
                  />
                  <path
                    d="M10 11 h12 M10 15 h12 M10 19 h8 M10 23 h6"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                  />
                </svg>
              )}
            </span>
            <h3 class="pcard__label">{p.label}</h3>
            <p class="pcard__descriptor">{p.descriptor}</p>
            <a href={p.href} class="pcard__link">
              Read more
              <svg viewBox="0 0 16 16" width="12" height="12" fill="none" aria-hidden="true">
                <path
                  d="M3 8 h10 M9 4 l4 4 -4 4"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .portal {
    background: #ffffff;
    padding: clamp(3.5rem, 7vw, 6rem) clamp(1.25rem, 4vw, 3rem);
    border-bottom: 1px solid #edeae2;
  }
  .portal__inner {
    max-width: 80rem;
    margin: 0 auto;
  }
  .portal__head {
    max-width: 50ch;
    margin-bottom: clamp(2rem, 3.5vw, 2.75rem);
  }
  .portal__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    color: #005a35;
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 0.75rem;
    display: inline-flex;
    align-items: center;
  }
  .portal__title {
    font-size: clamp(1.625rem, 2.8vw, 2.125rem);
    font-weight: 700;
    color: #0a0f1f;
    margin: 0 0 0.75rem;
    letter-spacing: -0.018em;
    line-height: 1.08;
  }
  .portal__lede {
    color: #384251;
    margin: 0;
    max-width: 54ch;
    line-height: 1.55;
    font-size: 1.0625rem;
  }

  .portal__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 48rem) {
    .portal__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .pcard {
    position: relative;
    background: #f7f7f5;
    border: 1px solid #e5e0d6;
    border-radius: 6px;
    padding: 2rem 1.5rem 1.625rem;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition:
      transform 340ms cubic-bezier(0.2, 0.9, 0.3, 1),
      box-shadow 340ms ease,
      background 240ms ease;
  }
  .pcard:hover {
    transform: translateY(-5px);
    background: #fff;
    box-shadow: 0 22px 48px -22px rgba(0, 40, 24, 0.24);
  }

  /* Top-edge three-colour Kente accent that fills in on hover. */
  .pcard__thread {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(
      90deg,
      #006b3f 0%,
      #006b3f 33%,
      #fcd116 33%,
      #fcd116 66%,
      #ce1126 66%,
      #ce1126 100%
    );
    transform-origin: left;
    transform: scaleX(0.3);
    transition: transform 480ms cubic-bezier(0.2, 0.9, 0.3, 1);
  }
  .pcard:hover .pcard__thread {
    transform: scaleX(1);
  }

  /* Icon chip with a gold glow that ramps in on hover. */
  .pcard__icon {
    position: relative;
    color: #005a35;
    background: #fff;
    border-radius: 6px;
    width: 56px;
    height: 56px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.125rem;
    border: 1px solid #e5e0d6;
    transition:
      border-color 240ms ease,
      transform 320ms cubic-bezier(0.2, 0.9, 0.3, 1);
    isolation: isolate;
  }
  .pcard__icon svg {
    position: relative;
    z-index: 1;
  }
  .pcard__icon-glow {
    position: absolute;
    inset: -4px;
    border-radius: 8px;
    background: radial-gradient(circle, rgba(252, 209, 22, 0.55) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 320ms ease;
    z-index: 0;
  }
  .pcard:hover .pcard__icon {
    border-color: #005a35;
    transform: translateY(-3px) rotate(-3deg);
  }
  .pcard:hover .pcard__icon-glow {
    opacity: 1;
  }

  .pcard__label {
    font-size: 1.1875rem;
    font-weight: 600;
    color: #0a0f1f;
    margin: 0 0 0.5rem;
    line-height: 1.3;
    letter-spacing: -0.005em;
  }
  .pcard__descriptor {
    font-size: 0.9375rem;
    color: #384251;
    line-height: 1.55;
    margin: 0 0 1.25rem;
    flex: 1;
  }
  .pcard__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #005a35;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
    align-self: flex-start;
    transition: border-color 180ms ease;
  }
  .pcard__link:hover,
  .pcard__link:focus-visible {
    border-bottom-color: #005a35;
  }
  .pcard__link:focus-visible {
    outline: 3px solid #fcd116;
    outline-offset: 3px;
    border-radius: 2px;
  }
  .pcard__link svg {
    transition: transform 260ms cubic-bezier(0.2, 0.9, 0.3, 1);
  }
  .pcard:hover .pcard__link svg {
    transform: translateX(4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .pcard,
    .pcard__icon,
    .pcard__icon-glow,
    .pcard__thread,
    .pcard__link svg {
      transition: none;
    }
    .pcard:hover {
      transform: none;
    }
    .pcard:hover .pcard__icon {
      transform: none;
    }
    .pcard__thread {
      transform: scaleX(1);
    }
  }
</style>
