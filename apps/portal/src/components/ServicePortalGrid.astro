---
/**
 * Service portal grid — gov.rw's "Irembo / Business / Tax / Procurement" row.
 *
 * Three cards, each with a simple line icon, heading, descriptor, and a
 * "Read more" link pointing to the specific service entry point.
 */
interface Portal {
  href: string;
  label: string;
  descriptor: string;
  icon: 'id' | 'business' | 'tax';
}

const portals: ReadonlyArray<Portal> = [
  {
    href: '/services/apply-ghana-card/',
    label: 'National ID (Ghana Card)',
    descriptor:
      'Apply for or renew your Ghana Card — also your Taxpayer Identification Number (TIN).',
    icon: 'id',
  },
  {
    href: '/services/register-business/',
    label: 'Business registration',
    descriptor:
      'Register a sole proprietorship, partnership, or limited company with the Registrar of Companies.',
    icon: 'business',
  },
  {
    href: '/services/file-income-tax/',
    label: 'Tax filing & payment',
    descriptor:
      'File annual income tax returns and pay via MoMo, bank, or through the GRA taxpayer portal.',
    icon: 'tax',
  },
];
---

<section class="portal" aria-labelledby="portal-heading">
  <div class="portal__inner">
    <header class="portal__head">
      <p class="portal__eyebrow">Most-used services</p>
      <h2 id="portal-heading" class="portal__title">Official service entry points.</h2>
      <p class="portal__lede">
        The three services Ghanaians use most often, with direct links to the responsible agency.
      </p>
    </header>

    <div class="portal__grid">
      {
        portals.map((p) => (
          <article class="card">
            <span class="card__icon" aria-hidden="true">
              {p.icon === 'id' && (
                <svg viewBox="0 0 32 32" width="30" height="30" fill="none">
                  <rect
                    x="4"
                    y="8"
                    width="24"
                    height="18"
                    rx="2"
                    stroke="currentColor"
                    stroke-width="1.6"
                  />
                  <circle cx="11" cy="15" r="3" stroke="currentColor" stroke-width="1.6" />
                  <path
                    d="M7 22 Q 7 18 11 18 T 15 22"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                  />
                  <path
                    d="M18 14 h7 M18 17 h7 M18 20 h5"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                  />
                </svg>
              )}
              {p.icon === 'business' && (
                <svg viewBox="0 0 32 32" width="30" height="30" fill="none">
                  <path
                    d="M6 27 V13 L13 13 V8 L19 8 V15 L26 15 V27 Z"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linejoin="round"
                  />
                  <path
                    d="M10 27 v-4 h3 v4 M16 27 v-4 h3 v4 M22 27 v-4 h2 v4"
                    stroke="currentColor"
                    stroke-width="1.4"
                  />
                </svg>
              )}
              {p.icon === 'tax' && (
                <svg viewBox="0 0 32 32" width="30" height="30" fill="none">
                  <rect
                    x="6"
                    y="5"
                    width="20"
                    height="22"
                    rx="2"
                    stroke="currentColor"
                    stroke-width="1.6"
                  />
                  <path
                    d="M10 11 h12 M10 15 h12 M10 19 h8 M10 23 h6"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                  />
                </svg>
              )}
            </span>
            <h3 class="card__label">{p.label}</h3>
            <p class="card__descriptor">{p.descriptor}</p>
            <a href={p.href} class="card__link">
              Read more
              <svg viewBox="0 0 16 16" width="12" height="12" fill="none" aria-hidden="true">
                <path
                  d="M3 8 h10 M9 4 l4 4 -4 4"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .portal {
    background: #ffffff;
    padding: clamp(3rem, 6vw, 5rem) clamp(1.25rem, 4vw, 3rem);
    border-bottom: 1px solid #edeae2;
  }
  .portal__inner {
    max-width: 80rem;
    margin: 0 auto;
  }
  .portal__head {
    max-width: 50ch;
    margin-bottom: clamp(1.75rem, 3vw, 2.5rem);
  }
  .portal__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: #005a35;
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .portal__title {
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    font-weight: 700;
    color: #0a0f1f;
    margin: 0 0 0.625rem;
    letter-spacing: -0.015em;
  }
  .portal__lede {
    color: #384251;
    margin: 0;
    max-width: 54ch;
    line-height: 1.55;
  }

  .portal__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 48rem) {
    .portal__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .card {
    background: #f7f7f5;
    border: 1px solid #e5e0d6;
    border-radius: 4px;
    padding: 1.75rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    transition:
      transform 200ms cubic-bezier(0.2, 0.9, 0.3, 1),
      box-shadow 200ms ease;
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 32px -16px rgba(0, 40, 24, 0.16);
  }
  .card__icon {
    color: #005a35;
    background: #fff;
    border-radius: 4px;
    width: 52px;
    height: 52px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.125rem;
    border: 1px solid #e5e0d6;
  }
  .card__label {
    font-size: 1.125rem;
    font-weight: 600;
    color: #0a0f1f;
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }
  .card__descriptor {
    font-size: 0.9375rem;
    color: #384251;
    line-height: 1.5;
    margin: 0 0 1.25rem;
    flex: 1;
  }
  .card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #005a35;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    align-self: flex-start;
    transition: border-color 180ms ease;
  }
  .card__link:hover,
  .card__link:focus-visible {
    border-bottom-color: #005a35;
  }
  .card__link svg {
    transition: transform 200ms cubic-bezier(0.2, 0.9, 0.3, 1);
  }
  .card:hover .card__link svg {
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    .card,
    .card__link svg {
      transition: none;
    }
    .card:hover {
      transform: none;
    }
  }
</style>
