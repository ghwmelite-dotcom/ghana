---
/**
 * Welcome strip — coat of arms crest + three key facts about Ghana. Sits
 * immediately under the hero as the "introductory handshake" moment,
 * replacing what the old stats-band + get-to-know-Ghana sections did.
 */
import { Image } from 'astro:assets';
import coatOfArms from '../assets/photos/coat-of-arms.png';
import ghanaMap from '../assets/photos/ghana-map-flag.png';

const facts = [
  { value: '32M', label: 'Citizens' },
  { value: '16', label: 'Regions' },
  { value: '21', label: 'Ministries' },
  { value: '1957', label: 'Independence' },
];
---

<section class="welcome" aria-labelledby="welcome-heading">
  <div class="welcome__inner">
    <div class="welcome__intro">
      <figure class="welcome__crest" aria-hidden="true">
        <Image src={coatOfArms} alt="" widths={[160, 240]} sizes="120px" quality={90} />
      </figure>
      <div>
        <p class="welcome__eyebrow">Republic of Ghana</p>
        <h2 id="welcome-heading" class="welcome__title">Freedom and Justice. Since 1957.</h2>
        <p class="welcome__lede">
          Ghana was the first sub-Saharan African country to gain independence from colonial rule.
          Today, 32 million Ghanaians across 16 regions live under one of Africa's most stable
          constitutional democracies.
          <a href="/about/">Learn more about the Republic →</a>
        </p>
      </div>
    </div>

    <div class="welcome__facts" aria-label="Ghana at a glance">
      <figure class="welcome__map" aria-hidden="true">
        <Image src={ghanaMap} alt="" widths={[120, 180]} sizes="100px" quality={90} />
      </figure>
      <dl class="welcome__stats">
        {
          facts.map((f) => (
            <div class="welcome__stat">
              <dt>{f.label}</dt>
              <dd>{f.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </div>
</section>

<style>
  .welcome {
    background: #0a0f1f;
    color: #fff;
    padding: clamp(3rem, 5vw, 4.5rem) clamp(1.25rem, 4vw, 3rem);
    border-top: 3px solid #fcd116;
    position: relative;
  }
  .welcome::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(
      90deg,
      #006b3f 0%,
      #006b3f 33%,
      #fcd116 33%,
      #fcd116 66%,
      #ce1126 66%,
      #ce1126 100%
    );
  }
  .welcome__inner {
    max-width: 80rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 3rem);
    align-items: center;
  }
  @media (min-width: 64rem) {
    .welcome__inner {
      grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
      gap: clamp(3rem, 6vw, 5rem);
    }
  }
  .welcome__intro {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    align-items: start;
  }
  @media (min-width: 40rem) {
    .welcome__intro {
      grid-template-columns: 90px minmax(0, 1fr);
      gap: 1.5rem;
    }
  }
  .welcome__crest {
    margin: 0;
    width: 90px;
  }
  .welcome__crest :global(img) {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 8px 22px rgba(0, 0, 0, 0.6));
  }
  .welcome__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    color: #fcd116;
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .welcome__title {
    font-size: clamp(1.5rem, 2.8vw, 2.125rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.75rem;
    letter-spacing: -0.015em;
    line-height: 1.12;
  }
  .welcome__lede {
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.55;
    margin: 0;
    font-size: 1rem;
    max-width: 60ch;
  }
  .welcome__lede a {
    color: #fcd116;
    font-weight: 500;
    text-decoration-color: rgba(252, 209, 22, 0.5);
    white-space: nowrap;
  }
  .welcome__lede a:hover {
    text-decoration-color: #fcd116;
  }

  .welcome__facts {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1.5rem;
    align-items: center;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(252, 209, 22, 0.25);
    border-radius: 4px;
  }
  .welcome__map {
    margin: 0;
    width: 80px;
    opacity: 0.9;
  }
  .welcome__map :global(img) {
    width: 100%;
    height: auto;
  }
  .welcome__stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.875rem 1.5rem;
    margin: 0;
  }
  @media (min-width: 24rem) {
    .welcome__stats {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  @media (min-width: 64rem) {
    .welcome__stats {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .welcome__stat dt {
    font-size: 0.625rem;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 0.2rem;
  }
  .welcome__stat dd {
    margin: 0;
    font-size: clamp(1.625rem, 2.4vw, 1.875rem);
    font-weight: 700;
    color: #fcd116;
    letter-spacing: -0.02em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
</style>
