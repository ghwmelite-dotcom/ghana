---
import BaseLayout from '../layouts/BaseLayout.astro';
import MostRequestedBand from '@gh/gh-ds/MostRequestedBand';

const mostRequested = [
  { label: 'Services', href: '/services/' },
  { label: 'News', href: '/news/' },
  { label: 'Ministries', href: '/ministries/' },
  { label: 'Search', href: '/search/' },
];
---

<BaseLayout title="Page not found" description="The page you requested could not be found.">
  <div class="notfound">
    <p class="eyebrow">404 · Yɛ anhu</p>
    <h1>We can't find that page.</h1>
    <p class="lede">
      The page may have moved, or the link you followed may be out of date. These
      are the places most people go next.
    </p>

    <form action="/search/" method="get" role="search" class="notfound__search">
      <label class="sr-only" for="nf-q">Search the portal</label>
      <input id="nf-q" name="q" type="search" placeholder="Search services, news, ministries…" />
      <button type="submit">Search</button>
    </form>

    <MostRequestedBand
      id="notfound-quick"
      title="Quick links"
      headingLevel="h2"
      items={mostRequested}
    />

    <p class="home-link">
      <a href="/">← Back to the homepage</a>
    </p>
  </div>
</BaseLayout>

<style>
  .notfound {
    max-width: 44rem;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 4rem;
  }
  .eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    color: #820b18;
    text-transform: uppercase;
    margin: 0 0 0.75rem;
    font-weight: 600;
  }
  h1 {
    font-family: Georgia, 'Playfair Display', serif;
    font-size: clamp(2rem, 5vw, 2.75rem);
    line-height: 1.05;
    color: #004527;
    margin: 0 0 0.75rem;
  }
  .lede {
    font-size: 1.125rem;
    color: #3e424a;
    max-width: 44ch;
    margin: 0 0 1.5rem;
  }
  .notfound__search {
    display: flex;
    background: #fff;
    border: 1.5px solid #005a35;
    border-radius: 4px;
    overflow: hidden;
    max-width: 32rem;
    margin-bottom: 2rem;
  }
  .notfound__search input {
    flex: 1;
    border: 0;
    padding: 0.75rem 1rem;
    font: inherit;
    background: transparent;
  }
  .notfound__search input:focus {
    outline: 3px solid #fcd116;
    outline-offset: -3px;
  }
  .notfound__search button {
    border: 0;
    background: #005a35;
    color: #fff;
    padding: 0 1.25rem;
    font: inherit;
    font-weight: 600;
    cursor: pointer;
    min-width: 44px;
  }
  .notfound__search button:hover {
    background: #004527;
  }
  .home-link {
    margin-top: 1.5rem;
    font-size: 0.9375rem;
  }
  .home-link a {
    color: #004527;
    text-decoration: none;
  }
  .home-link a:hover,
  .home-link a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }
  .home-link a:focus-visible {
    outline: 3px solid #fcd116;
    outline-offset: 2px;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
