---
import { getEntry } from 'astro:content';
import BoilerplatePageLayout from '../layouts/BoilerplatePageLayout.astro';

const entry = await getEntry('pages', 'accessibility');
if (!entry) throw new Error('pages/accessibility.md missing');
const { Content } = await entry.render();
---

<BoilerplatePageLayout
  title={entry.data.title}
  description={entry.data.lede}
  lede={entry.data.lede}
  updatedAt={entry.data.updatedAt}
>
  <Content />
</BoilerplatePageLayout>
