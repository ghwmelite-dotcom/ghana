---
/**
 * gov.gh homepage — gov.rw-aligned composition.
 *
 * Section order mirrors gov.rw:
 *   1. Hero (text-forward, integrated search, quiet photo)
 *   2. Life-stage tile grid (4 tiles with line icons)
 *   3. "Get to know Ghana" intro block with crest + learn-more
 *   4. Most-used services portal grid (3 cards with icons)
 *   5. Latest updates — news cards with thumbnails
 *   6. Ministries quick-access grid
 *
 * Deliberately excluded: stats band, scrolling marquee, closing motto,
 * orchestrated gold threads, constellation. gov.rw is calm.
 */
import HomepageLayout from '../layouts/HomepageLayout.astro';
import Hero from '../components/Hero.astro';
import LifeStageTiles from '../components/LifeStageTiles.astro';
import GetToKnowGhana from '../components/GetToKnowGhana.astro';
import ServicePortalGrid from '../components/ServicePortalGrid.astro';
import EditorialNews from '../components/EditorialNews.astro';
import MinistriesRow from '../components/MinistriesRow.astro';
---

<HomepageLayout
  title="Home"
  description="The official digital portal of the Government of Ghana. Every service, every ministry, every announcement — in one place."
>
  <Hero />
  <LifeStageTiles />
  <GetToKnowGhana />
  <ServicePortalGrid />
  <EditorialNews />
  <MinistriesRow />
</HomepageLayout>
