---
/**
 * gov.gh homepage — "gov.rw structure, Ghanaian soul."
 *
 * Section order: dramatic photographic hero → dark welcome strip with crest
 * and facts → life-stage tile grid → 3-card service portal → heritage
 * monuments gallery → news row → ministries directory → closing motto.
 */
import HomepageLayout from '../layouts/HomepageLayout.astro';
import Hero from '../components/Hero.astro';
import WelcomeStrip from '../components/WelcomeStrip.astro';
import LifeStageTiles from '../components/LifeStageTiles.astro';
import ServicePortalGrid from '../components/ServicePortalGrid.astro';
import MonumentsGallery from '../components/MonumentsGallery.astro';
import EditorialNews from '../components/EditorialNews.astro';
import MinistriesRow from '../components/MinistriesRow.astro';
import ClosingMotto from '../components/ClosingMotto.astro';
---

<HomepageLayout
  title="Home"
  description="The official digital portal of the Government of Ghana. Every service, every ministry, every announcement — in one place."
>
  <Hero />
  <WelcomeStrip />
  <LifeStageTiles />
  <ServicePortalGrid />
  <MonumentsGallery />
  <EditorialNews />
  <MinistriesRow />
  <ClosingMotto />
</HomepageLayout>
