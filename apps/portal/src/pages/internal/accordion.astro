---
/**
 * Hidden Accordion gallery — served at `/internal/accordion/`.
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Accordion from '@gh/gh-ds/Accordion';
import AccordionItem from '@gh/gh-ds/AccordionItem';
---

<BaseLayout
  title="Accordion — internal test"
  description="Internal test page for GH-DS Accordion. Not linked from public navigation."
  noindex
>
  <h1>Accordion</h1>
  <p>
    Not public. Exercises <code>@gh/gh-ds/Accordion</code> plus
    <code>AccordionItem</code> — both built on native
    <code>&lt;details&gt;</code> for progressive enhancement.
  </p>

  <section aria-labelledby="h-faq">
    <h2 id="h-faq">Passport renewal FAQs</h2>

    <Accordion id="faq-passport">
      <AccordionItem heading="How long does a renewal take?">
        <p>
          Most renewals are processed within 7 working days. Renewals during peak periods (January
          and August) may take up to 14 days.
        </p>
      </AccordionItem>

      <AccordionItem heading="What if I lost my old passport?">
        <p>
          Report the loss at any Ghana Immigration Service office before you apply for a new one.
          Bring your Ghana Card and a signed police report. Fees are the same as for a standard
          renewal.
        </p>
      </AccordionItem>

      <AccordionItem heading="Can I renew from outside Ghana?">
        <p>
          Yes. Go to any Ghanaian diplomatic mission. You pay the standard fee plus a processing
          charge set by the mission. Diaspora renewals are typically ready in 3 to 6 weeks.
        </p>
      </AccordionItem>

      <AccordionItem heading="Do I need an appointment?" open>
        <p>
          Yes for passport offices in Accra, Kumasi, and Tamale. Book through the passport portal.
          For offices in other regions, walk-ins are accepted between 08:00 and 12:00.
        </p>
      </AccordionItem>
    </Accordion>
  </section>

  <section aria-labelledby="h-short">
    <h2 id="h-short">Short accordion</h2>
    <Accordion id="faq-short">
      <AccordionItem heading="Single item accordion">
        <p>Occasionally useful as a "read more" affordance.</p>
      </AccordionItem>
    </Accordion>
  </section>

  <section aria-labelledby="h-twi" lang="tw">
    <h2 id="h-twi" lang="en">Twi fixture</h2>
    <div lang="tw">
      <Accordion id="faq-twi">
        <AccordionItem heading="Adwuma no bere ye sen?">
          <p>Mfe nson mu na wobɛma wo passport no foforɔ.</p>
        </AccordionItem>
        <AccordionItem heading="Me passport ayera. Yɛbɛyɛ dɛn?">
          <p>Kɔ Ghana Immigration Service dan mu na wone wɔn bɛkasa.</p>
        </AccordionItem>
      </Accordion>
    </div>
  </section>
</BaseLayout>

<style>
  section {
    border-top: var(--border-width-hairline) solid var(--color-border-default);
    margin-top: var(--space-8);
    padding-top: var(--space-4);
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.95em;
    background: var(--ghana-ink-50);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }
</style>
