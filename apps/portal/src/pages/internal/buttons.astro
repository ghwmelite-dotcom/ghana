---
/**
 * Hidden Button-variant gallery — built only so axe-check and future visual
 * regression runs have every variant on a single page. Robots are excluded
 * via meta noindex; the page is not linked from anywhere in the public site.
 *
 * Served at `/internal/buttons/` and safe to scan in CI:
 *   - axe-check walks every HTML file in dist, so it finds this automatically.
 *   - measure-weight only inspects `/`, so this page does not contribute to
 *     the 80 KB budget on the homepage.
 *   - Lighthouse CI only runs against `/` per .lighthouserc.cjs.
 *
 * Delete this route if Storybook lands (planned alongside apps/design-system
 * in Weeks 3–6).
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '@gh/gh-ds/Button';
---

<BaseLayout
  title="Button variants — internal test"
  description="Internal test page for GH-DS Button variants. Not linked from public navigation."
  noindex
>
  <h1>Button variants</h1>
  <p>
    Not public. This page exercises every variant, size, and state of the
    <code>@gh/gh-ds/Button</code> component so axe-core can verify accessibility coverage.
  </p>

  <section aria-labelledby="h-primary">
    <h2 id="h-primary">Primary</h2>
    <div class="row">
      <Button variant="primary">Continue</Button>
      <Button variant="primary" size="lg">Continue (large)</Button>
      <Button variant="primary" disabled>Continue (disabled)</Button>
    </div>
  </section>

  <section aria-labelledby="h-secondary">
    <h2 id="h-secondary">Secondary</h2>
    <div class="row">
      <Button variant="secondary">Back</Button>
      <Button variant="secondary" size="lg">Back (large)</Button>
      <Button variant="secondary" disabled>Back (disabled)</Button>
    </div>
  </section>

  <section aria-labelledby="h-warning">
    <h2 id="h-warning">Warning (destructive)</h2>
    <div class="row">
      <Button variant="warning">Delete application</Button>
      <Button variant="warning" disabled>Delete (disabled)</Button>
    </div>
  </section>

  <section aria-labelledby="h-start">
    <h2 id="h-start">Start</h2>
    <div class="row">
      <Button variant="start" href="/services/passport/renew">
        Start now: renew your passport
      </Button>
      <Button variant="start">Start now</Button>
    </div>
  </section>

  <section aria-labelledby="h-link">
    <h2 id="h-link">Rendered as link (role=button)</h2>
    <div class="row">
      <Button variant="primary" href="/services/ghana-card"> Apply for the Ghana Card </Button>
      <Button variant="primary" href="/services/ghana-card" disabled> Apply (unavailable) </Button>
    </div>
  </section>

  <section aria-labelledby="h-twi" lang="tw">
    <h2 id="h-twi" lang="en">Twi labels</h2>
    <div class="row">
      <Button variant="primary">Toa so</Button>
      <Button variant="warning">Popa</Button>
      <Button variant="start">Fi ase seesei</Button>
    </div>
  </section>
</BaseLayout>

<style>
  .row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding-block: var(--space-4);
  }

  section {
    border-top: var(--border-width-hairline) solid var(--color-border-default);
    margin-top: var(--space-8);
    padding-top: var(--space-4);
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.95em;
    background: var(--ghana-ink-50);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }
</style>
