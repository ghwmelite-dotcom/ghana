---
/**
 * Hidden Radio + Checkbox variant gallery — paired with axe-check.
 * Served at `/internal/choices/`. Not linked from public navigation.
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import RadioGroup from '@gh/gh-ds/RadioGroup';
import CheckboxGroup from '@gh/gh-ds/CheckboxGroup';
import Button from '@gh/gh-ds/Button';
---

<BaseLayout
  title="Choices — RadioGroup + CheckboxGroup test"
  description="Internal test page for GH-DS RadioGroup and CheckboxGroup. Not linked from public navigation."
  noindex
>
  <h1>Choices — RadioGroup + CheckboxGroup</h1>
  <p>
    Not public. Exercises every state, orientation, and per-option condition of
    <code>@gh/gh-ds/RadioGroup</code> and <code>@gh/gh-ds/CheckboxGroup</code>.
  </p>

  <form action="#" method="post" novalidate>
    <section aria-labelledby="h-radio-inline">
      <h2 id="h-radio-inline">Radio — inline binary</h2>
      <RadioGroup
        name="has-card"
        legend="Do you have a Ghana Card?"
        orientation="inline"
        required
        options={[
          { value: 'yes', label: 'Yes' },
          { value: 'no', label: 'No' },
        ]}
      />
    </section>

    <section aria-labelledby="h-radio-long">
      <h2 id="h-radio-long">Radio — longer list with preselection</h2>
      <RadioGroup
        name="language"
        legend="Which language do you use most often?"
        hint="We use this to show you service pages in the right language."
        value="en"
        options={[
          { value: 'en', label: 'English' },
          { value: 'tw', label: 'Twi' },
          { value: 'ew', label: 'Ewe' },
          { value: 'gaa', label: 'Ga' },
          { value: 'dag', label: 'Dagbani' },
          { value: 'ha', label: 'Hausa' },
        ]}
      />
    </section>

    <section aria-labelledby="h-radio-hints">
      <h2 id="h-radio-hints">Radio — per-option hints</h2>
      <RadioGroup
        name="contact-method"
        legend="How should we contact you about your application?"
        options={[
          {
            value: 'sms',
            label: 'SMS',
            hint: 'We will text the number you gave us.',
          },
          {
            value: 'email',
            label: 'Email',
            hint: 'Usually faster if you check your inbox regularly.',
          },
          {
            value: 'post',
            label: 'Post',
            hint: 'Adds 3 to 5 working days to any reply.',
          },
        ]}
      />
    </section>

    <section aria-labelledby="h-radio-error">
      <h2 id="h-radio-error">Radio — error state</h2>
      <RadioGroup
        name="consent"
        legend="Do you agree to the data-processing notice?"
        orientation="inline"
        error="Select yes or no to continue"
        required
        options={[
          { value: 'yes', label: 'Yes' },
          { value: 'no', label: 'No' },
        ]}
      />
    </section>

    <section aria-labelledby="h-radio-disabled">
      <h2 id="h-radio-disabled">Radio — disabled option</h2>
      <RadioGroup
        name="office"
        legend="Which regional office will you visit?"
        options={[
          { value: 'accra', label: 'Accra' },
          { value: 'kumasi', label: 'Kumasi' },
          { value: 'tamale', label: 'Tamale' },
          {
            value: 'bolgatanga',
            label: 'Bolgatanga',
            hint: 'Temporarily closed for renovations.',
            disabled: true,
          },
        ]}
      />
    </section>

    <section aria-labelledby="h-check-multi">
      <h2 id="h-check-multi">Checkbox — multi-select</h2>
      <CheckboxGroup
        name="services"
        legend="Which services do you need today?"
        hint="Select all that apply."
        value={['passport']}
        options={[
          { value: 'passport', label: 'Passport renewal' },
          { value: 'card', label: 'Ghana Card' },
          { value: 'tax', label: 'File a tax return' },
          { value: 'business', label: 'Register a business' },
          { value: 'licence', label: 'Driving licence' },
        ]}
      />
    </section>

    <section aria-labelledby="h-check-inline">
      <h2 id="h-check-inline">Checkbox — inline binary</h2>
      <CheckboxGroup
        name="updates"
        legend="Send me updates about:"
        orientation="inline"
        options={[
          { value: 'services', label: 'New services' },
          { value: 'outages', label: 'Planned outages' },
          { value: 'news', label: 'Government news' },
        ]}
      />
    </section>

    <section aria-labelledby="h-check-single">
      <h2 id="h-check-single">Checkbox — single accept-terms pattern</h2>
      <CheckboxGroup
        name="terms"
        legend="Accept the terms and conditions"
        legendHidden
        nameIsArray={false}
        required
        options={[
          {
            value: 'accepted',
            label:
              'I accept the data-processing notice and confirm the information I give is true.',
          },
        ]}
      />
    </section>

    <section aria-labelledby="h-check-error">
      <h2 id="h-check-error">Checkbox — error state</h2>
      <CheckboxGroup
        name="notices"
        legend="Which notices do you want to receive?"
        error="Select at least one notice type"
        required
        options={[
          { value: 'sms', label: 'SMS' },
          { value: 'email', label: 'Email' },
        ]}
      />
    </section>

    <section aria-labelledby="h-twi" lang="tw">
      <h2 id="h-twi" lang="en">Twi fixture</h2>
      <div lang="tw">
        <RadioGroup
          name="kasa"
          legend="Kasa bɛn na wote?"
          options={[
            { value: 'tw', label: 'Twi' },
            { value: 'ew', label: 'Ewegbe' },
            { value: 'ga', label: 'Ga' },
          ]}
        />
        <CheckboxGroup
          name="adwuma"
          legend="Dwuma bɛn na wopɛ sɛ woyɛ?"
          options={[
            { value: 'passport', label: 'Passport' },
            { value: 'card', label: 'Ghana Card' },
            { value: 'tax', label: 'Tow' },
          ]}
        />
      </div>
    </section>

    <div class="submit-row">
      <Button type="submit">Send demo</Button>
    </div>
  </form>
</BaseLayout>

<style>
  section {
    border-top: var(--border-width-hairline) solid var(--color-border-default);
    margin-top: var(--space-8);
    padding-top: var(--space-4);
  }

  .submit-row {
    margin-top: var(--space-8);
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.95em;
    background: var(--ghana-ink-50);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }

  form {
    max-width: 42rem;
  }
</style>
