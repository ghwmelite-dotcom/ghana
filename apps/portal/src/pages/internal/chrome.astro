---
/**
 * Hidden portal-chrome gallery — CookieBanner in context, plus a
 * standalone Search and MostRequestedBand demo. The homepage `/` already
 * shows the latter two in their canonical position; this page gives axe
 * a look at alternative configurations.
 * Served at `/internal/chrome/`.
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import CookieBanner from '@gh/gh-ds/CookieBanner';
import Search from '@gh/gh-ds/Search';
import MostRequestedBand from '@gh/gh-ds/MostRequestedBand';
---

<BaseLayout
  title="Chrome — internal test"
  description="Internal test page for GH-DS Search, MostRequestedBand and CookieBanner."
  noindex
>
  <CookieBanner />

  <h1>Portal chrome</h1>
  <p>
    Not public. Exercises <code>@gh/gh-ds/CookieBanner</code> and alternate configurations of <code
      >Search</code
    > and <code>MostRequestedBand</code>
    (the canonical instances of those two components already render on
    <code>/</code>).
  </p>

  <section aria-labelledby="h-cookie-custom">
    <h2 id="h-cookie-custom">CookieBanner — custom title and body</h2>
    <CookieBanner id="banner-custom" title="Cookies on ohcs.gov.gh" policyHref="/cookies">
      <p>
        The Office of the Head of Civil Service uses cookies to keep this site working. We would
        like to use optional cookies to understand how you use it, so we can improve it. Your choice
        is stored on this device.
      </p>
    </CookieBanner>
  </section>

  <section aria-labelledby="h-search-sticky">
    <h2 id="h-search-sticky">Search — sticky on a results page</h2>
    <Search
      label="I am looking for…"
      action="/search"
      value="passport renewal"
      placeholder="Passport, Ghana Card, tax…"
    />
  </section>

  <section aria-labelledby="h-most-requested">
    <h2 id="h-most-requested">Most requested — eight-link OHCS seed</h2>
    <MostRequestedBand
      id="mr-internal"
      title="Most requested at OHCS"
      items={[
        { label: 'Civil Service Code', href: '/ohcs/code' },
        { label: 'RTI requests', href: '/ohcs/rti' },
        { label: 'Scheme of Service', href: '/ohcs/scheme' },
        { label: 'Performance management', href: '/ohcs/performance' },
        { label: 'Training programmes', href: '/ohcs/training' },
        { label: 'Annual reports', href: '/ohcs/reports' },
        { label: 'Contact OHCS', href: '/ohcs/contact' },
        { label: 'Anti-corruption policy', href: '/ohcs/anti-corruption' },
      ]}
    />
  </section>

  <section aria-labelledby="h-twi" lang="tw">
    <h2 id="h-twi" lang="en">Twi fixture</h2>
    <div lang="tw">
      <Search
        label="Merehwehwɛ…"
        action="/search"
        placeholder="Passport, Ghana Card…"
        buttonLabel="Hwehwɛ"
      />
    </div>
  </section>
</BaseLayout>

<style>
  section {
    border-top: var(--border-width-hairline) solid var(--color-border-default);
    margin-top: var(--space-8);
    padding-top: var(--space-4);
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.95em;
    background: var(--ghana-ink-50);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }
</style>
