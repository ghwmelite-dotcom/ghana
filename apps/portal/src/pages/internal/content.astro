---
/**
 * Hidden Tier-2 content-page starter-pack gallery — Breadcrumb + Card +
 * NotificationBanner. Served at `/internal/content/`.
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '@gh/gh-ds/Breadcrumb';
import Card from '@gh/gh-ds/Card';
import NotificationBanner from '@gh/gh-ds/NotificationBanner';
---

<BaseLayout
  title="Tier-2 content starter pack — internal test"
  description="Internal test page for GH-DS Breadcrumb, Card and NotificationBanner."
  noindex
>
  <Breadcrumb
    items={[
      { href: '/', label: 'Home' },
      { href: '/internal/', label: 'Internal' },
    ]}
    current="Content starter pack"
  />

  <h1>Tier-2 content starter pack</h1>
  <p>
    Not public. Exercises <code>@gh/gh-ds/Breadcrumb</code>,
    <code>Card</code> and <code>NotificationBanner</code>.
  </p>

  <section aria-labelledby="h-banners">
    <h2 id="h-banners">Notification banners</h2>

    <NotificationBanner id="banner-maintenance" type="info" title="Scheduled maintenance">
      <p>
        Payments are offline from 22:00 to 23:30 on 18 April 2026. Plan your application for after
        that window.
      </p>
    </NotificationBanner>

    <NotificationBanner id="banner-application-sent" type="success" title="Application sent">
      <p>
        Your ARN is <strong>ARN-2026-04-000123</strong>. We will text
        <span class="nowrap">+233 244 123 456</span> your next step within 48 hours.
      </p>
    </NotificationBanner>

    <NotificationBanner
      id="banner-ghana-card-down"
      type="warning"
      title="Service temporarily unavailable"
    >
      <p>
        The Ghana Card verification service is down for emergency maintenance. Try again after 16:00
        today.
      </p>
    </NotificationBanner>
  </section>

  <section aria-labelledby="h-cards">
    <h2 id="h-cards">Cards</h2>

    <Card title="About this card">
      <p>
        Static cards wrap any content. Use for feature blurbs, sidebar notes, or any section that
        should read as a visual unit.
      </p>
    </Card>

    <Card
      title="Renew your passport"
      description="Renew your Ghanaian passport in four steps. Typical processing: 7 working days."
      href="/services/passport/renew"
    />

    <Card
      title="Apply for the Ghana Card"
      description="Register if you are 15 or over and have not registered yet."
      href="/services/ghana-card"
    />

    <Card
      title="File your tax return"
      description="Most individuals must file by 30 April each year."
      href="/services/tax/file"
    />
  </section>

  <section aria-labelledby="h-twi" lang="tw">
    <h2 id="h-twi" lang="en">Twi fixture</h2>
    <div lang="tw">
      <NotificationBanner id="banner-twi" type="info" title="Yɛreyɛ ho adwuma">
        <p>Kɔntam ne ɛka ho adwuma no nni adwuma ɛnnɛ ɛne ɔkyena.</p>
      </NotificationBanner>

      <Card
        title="Ghana Card"
        description="Kyerɛw wo din sɛ wodi mfeɛ 15 ne ntam na wunkyerɛw wo din."
        href="/services/ghana-card"
      />
    </div>
  </section>
</BaseLayout>

<style>
  section {
    border-top: var(--border-width-hairline) solid var(--color-border-default);
    margin-top: var(--space-8);
    padding-top: var(--space-4);
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.95em;
    background: var(--ghana-ink-50);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }

  .nowrap {
    white-space: nowrap;
  }
</style>
