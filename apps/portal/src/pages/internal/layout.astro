---
/**
 * Hidden layout-piece gallery — SkipLink, Header, Footer, BackLink.
 * Served at `/internal/layout/`.
 *
 * The Header and Footer are rendered once on every page by BaseLayout, so
 * this page focuses on BackLink variants. SkipLink is testable by pressing
 * Tab once on any page — it appears at the top-left.
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import BackLink from '@gh/gh-ds/BackLink';
---

<BaseLayout
  title="Layout components — internal test"
  description="Internal test page for SkipLink, Header, Footer and BackLink. Not linked from public navigation."
  noindex
>
  <h1>Layout components</h1>
  <p>
    Not public. The <code>Header</code> and <code>Footer</code> are rendered on every page, including
    this one — visible above and below. <code>SkipLink</code>
    is the first focusable element in every page's <code>body</code>; press
    <kbd>Tab</kbd> on page load to see it appear at the top-left.
    <code>BackLink</code> variants are shown below.
  </p>

  <section aria-labelledby="h-default">
    <h2 id="h-default">Default</h2>
    <BackLink href="/" />
  </section>

  <section aria-labelledby="h-custom">
    <h2 id="h-custom">Custom label</h2>
    <BackLink href="/services/">Back to services</BackLink>
  </section>

  <section aria-labelledby="h-deep">
    <h2 id="h-deep">Deep context</h2>
    <BackLink href="/services/passport/">Back to passport services</BackLink>
  </section>

  <section aria-labelledby="h-twi" lang="tw">
    <h2 id="h-twi" lang="en">Twi label</h2>
    <div lang="tw">
      <BackLink href="/">Sankɔ</BackLink>
    </div>
  </section>

  <section aria-labelledby="h-note">
    <h2 id="h-note">Iconography note</h2>
    <p>
      Per <code>.claude/CLAUDE.md §6.3</code>, this control is mapped to the
      <strong>Sankofa</strong> Adinkra symbol. Shipping the Sankofa glyph requires clearance from the
      National Commission on Culture and Folklore Board (Copyright Act 690). Until that clearance lands,
      a generic left-chevron stands in and the component contract is unchanged. ADR-004 will document
      the swap.
    </p>
  </section>
</BaseLayout>

<style>
  section {
    border-top: var(--border-width-hairline) solid var(--color-border-default);
    margin-top: var(--space-8);
    padding-top: var(--space-4);
  }

  code,
  kbd {
    font-family: var(--font-mono);
    font-size: 0.95em;
    background: var(--ghana-ink-50);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }
</style>
