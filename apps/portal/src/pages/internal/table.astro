---
/**
 * Hidden Table gallery — served at `/internal/table/`.
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Table from '@gh/gh-ds/Table';
---

<BaseLayout
  title="Table — internal test"
  description="Internal test page for GH-DS Table. Not linked from public navigation."
  noindex
>
  <h1>Table</h1>
  <p>
    Not public. Exercises <code>@gh/gh-ds/Table</code> with a caption, numeric-aligned column, and scroll-on-narrow-viewport
    behaviour.
  </p>

  <section aria-labelledby="h-basic">
    <h2 id="h-basic">Passport fees</h2>

    <Table caption="Passport fees by type and route" id="fees">
      <thead>
        <tr>
          <th scope="col">Type</th>
          <th scope="col">Pages</th>
          <th scope="col" class="gh-table__cell--numeric">Standard fee</th>
          <th scope="col" class="gh-table__cell--numeric">Express fee</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Standard passport</td>
          <td>32</td>
          <td class="gh-table__cell--numeric">GH₵ 100</td>
          <td class="gh-table__cell--numeric">GH₵ 200</td>
        </tr>
        <tr>
          <td>Executive passport</td>
          <td>64</td>
          <td class="gh-table__cell--numeric">GH₵ 150</td>
          <td class="gh-table__cell--numeric">GH₵ 300</td>
        </tr>
        <tr>
          <td>Diplomatic passport</td>
          <td>64</td>
          <td class="gh-table__cell--numeric">GH₵ 250</td>
          <td class="gh-table__cell--numeric">—</td>
        </tr>
      </tbody>
    </Table>
  </section>

  <section aria-labelledby="h-row-headers">
    <h2 id="h-row-headers">Service availability by region</h2>

    <Table caption="Which passport services each regional office offers" id="services-by-region">
      <thead>
        <tr>
          <th scope="col">Region</th>
          <th scope="col">Renewal</th>
          <th scope="col">First-time apply</th>
          <th scope="col">Lost / stolen</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <th scope="row">Greater Accra</th>
          <td>Yes</td>
          <td>Yes</td>
          <td>Yes</td>
        </tr>
        <tr>
          <th scope="row">Ashanti (Kumasi)</th>
          <td>Yes</td>
          <td>Yes</td>
          <td>Yes</td>
        </tr>
        <tr>
          <th scope="row">Northern (Tamale)</th>
          <td>Yes</td>
          <td>Yes</td>
          <td>By appointment only</td>
        </tr>
        <tr>
          <th scope="row">Upper East (Bolgatanga)</th>
          <td>Yes</td>
          <td>No — travel to Tamale</td>
          <td>No — travel to Tamale</td>
        </tr>
      </tbody>
    </Table>
  </section>

  <section aria-labelledby="h-twi" lang="tw">
    <h2 id="h-twi" lang="en">Twi fixture</h2>
    <div lang="tw">
      <Table caption="Passport ho akatua" id="akatua">
        <thead>
          <tr>
            <th scope="col">Passport</th>
            <th scope="col" class="gh-table__cell--numeric">Ɛka</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Passport (kratasa 32)</td>
            <td class="gh-table__cell--numeric">GH₵ 100</td>
          </tr>
          <tr>
            <td>Passport (kratasa 64)</td>
            <td class="gh-table__cell--numeric">GH₵ 150</td>
          </tr>
        </tbody>
      </Table>
    </div>
  </section>
</BaseLayout>

<style>
  section {
    border-top: var(--border-width-hairline) solid var(--color-border-default);
    margin-top: var(--space-8);
    padding-top: var(--space-4);
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.95em;
    background: var(--ghana-ink-50);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }
</style>
