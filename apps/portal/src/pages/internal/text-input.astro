---
/**
 * Hidden TextInput variant gallery — paired with axe-check.
 * Served at `/internal/text-input/`. Not linked from public navigation.
 * Mirrors the structure of `internal/buttons.astro` so both are swept by the
 * same dist-walker in `apps/portal/scripts/axe-check.mjs`.
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '@gh/gh-ds/Button';
import TextInput from '@gh/gh-ds/TextInput';
---

<BaseLayout
  title="TextInput variants — internal test"
  description="Internal test page for GH-DS TextInput variants. Not linked from public navigation."
  noindex
>
  <h1>TextInput variants</h1>
  <p>
    Not public. Exercises every state, width, and input type of the
    <code>@gh/gh-ds/TextInput</code> component. axe-core runs against this page on every CI build.
  </p>

  <form class="demo-form" action="#" method="post" novalidate>
    <section aria-labelledby="h-basic">
      <h2 id="h-basic">Basic</h2>
      <TextInput name="full-name" label="Full name" autocomplete="name" />
      <TextInput
        name="email"
        label="Email"
        type="email"
        autocomplete="email"
        hint="We only use this to send your reference number."
      />
    </section>

    <section aria-labelledby="h-required">
      <h2 id="h-required">Required + hint</h2>
      <TextInput
        name="pin"
        label="Ghana Card PIN"
        hint="10 characters starting with GHA-"
        width="20"
        autocomplete="off"
        required
      />
    </section>

    <section aria-labelledby="h-error">
      <h2 id="h-error">Error state</h2>
      <TextInput
        name="phone"
        label="Mobile number"
        type="tel"
        hint="For example, 0244 123 456"
        width="20"
        error="Enter a valid Ghanaian mobile number"
        value="0244"
        autocomplete="tel"
      />
    </section>

    <section aria-labelledby="h-width">
      <h2 id="h-width">Width modifiers</h2>
      <TextInput name="dob-day" label="Day" width="2" inputmode="numeric" />
      <TextInput name="dob-month" label="Month" width="2" inputmode="numeric" />
      <TextInput name="dob-year" label="Year" width="4" inputmode="numeric" />
      <TextInput name="postcode" label="Postcode (GPS)" width="10" />
      <TextInput name="address" label="Street address" width="30" autocomplete="street-address" />
    </section>

    <section aria-labelledby="h-types">
      <h2 id="h-types">Input types</h2>
      <TextInput name="search-q" label="Search term" type="search" autocomplete="off" />
      <TextInput name="password" label="Password" type="password" autocomplete="current-password" />
      <TextInput name="website" label="Website" type="url" autocomplete="url" />
    </section>

    <section aria-labelledby="h-disabled">
      <h2 id="h-disabled">Disabled</h2>
      <TextInput name="locked" label="Application reference" value="ARN-2026-04-000123" disabled />
    </section>

    <section aria-labelledby="h-twi" lang="tw">
      <h2 id="h-twi" lang="en">Twi labels</h2>
      <TextInput name="din" label="Wo din" hint="Wo din nyinaa" />
      <TextInput name="mmoaakuo-din" label="Mmoaakuo din" hint="Adwuma a woyɛ" />
    </section>

    <div class="submit-row">
      <Button type="submit">Send demo</Button>
    </div>
  </form>
</BaseLayout>

<style>
  .demo-form {
    max-width: 42rem;
  }

  section {
    border-top: var(--border-width-hairline) solid var(--color-border-default);
    margin-top: var(--space-8);
    padding-top: var(--space-4);
  }

  .submit-row {
    margin-top: var(--space-8);
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.95em;
    background: var(--ghana-ink-50);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }
</style>
