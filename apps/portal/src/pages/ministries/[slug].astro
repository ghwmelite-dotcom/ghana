---
import { getCollection, type CollectionEntry } from 'astro:content';
import MinistryPageLayout from '../../layouts/MinistryPageLayout.astro';

export async function getStaticPaths() {
  const all = await getCollection('ministries');
  return all.map((entry: CollectionEntry<'ministries'>) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'ministries'>;
}
const { entry } = Astro.props as Props;
const { Content } = await entry.render();
---

<MinistryPageLayout entry={entry}>
  <Content />
</MinistryPageLayout>
