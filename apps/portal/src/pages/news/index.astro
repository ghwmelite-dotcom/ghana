---
import { getCollection, type CollectionEntry } from 'astro:content';
import BoilerplatePageLayout from '../../layouts/BoilerplatePageLayout.astro';

const news: CollectionEntry<'news'>[] = (await getCollection('news')).sort(
  (a: CollectionEntry<'news'>, b: CollectionEntry<'news'>) =>
    b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const formatter = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BoilerplatePageLayout
  title="News"
  description="Latest news and announcements from across the Government of Ghana."
  lede="Announcements, speeches, policy updates, and publications from across government. Newest first."
>
  {
    news.length === 0 ? (
      <p>News articles will appear here as they're published.</p>
    ) : (
      <ul class="news-list">
        {news.map((n) => (
          <li>
            <article class="entry">
              <p class="entry__eyebrow">
                {n.data.ministry.replace(/-/g, ' ').toUpperCase()} ·{' '}
                {formatter.format(n.data.publishedAt)}
              </p>
              <h2 class="entry__title">
                <a href={`/news/${n.data.publishedAt.getFullYear()}/${n.slug}/`}>{n.data.title}</a>
              </h2>
              <p class="entry__lede">{n.data.lede}</p>
            </article>
          </li>
        ))}
      </ul>
    )
  }
</BoilerplatePageLayout>

<style>
  .news-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .entry {
    background: #fff;
    border: 1px solid #e5e0d6;
    border-left: 3px solid #820b18;
    border-radius: 3px;
    padding: 1rem 1.25rem;
  }
  .entry__eyebrow {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    color: #820b18;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .entry__title {
    font-family: Georgia, serif;
    font-size: 1.25rem;
    line-height: 1.2;
    margin: 0 0 0.375rem;
  }
  .entry__title a {
    color: #004527;
    text-decoration: none;
  }
  .entry__title a:hover,
  .entry__title a:focus-visible {
    text-decoration: underline;
    text-decoration-thickness: 0.1em;
    text-underline-offset: 0.15em;
  }
  .entry__title a:focus-visible {
    outline: 3px solid #fcd116;
    outline-offset: 2px;
  }
  .entry__lede {
    font-size: 0.9375rem;
    color: #3e424a;
    margin: 0;
    line-height: 1.5;
  }
</style>
