---
import { getCollection, type CollectionEntry } from 'astro:content';
import ServicePageLayout from '../../layouts/ServicePageLayout.astro';

export async function getStaticPaths() {
  const RESERVED = new Set(['a-z', 'diaspora', 'live', 'work', 'business', 'visit']);
  const all = await getCollection('services');
  return all
    .filter((entry: CollectionEntry<'services'>) => !RESERVED.has(entry.slug))
    .map((entry: CollectionEntry<'services'>) => ({
      params: { slug: entry.slug },
      props: { entry },
    }));
}

interface Props {
  entry: CollectionEntry<'services'>;
}
const { entry } = Astro.props as Props;
const { Content } = await entry.render();
---

<ServicePageLayout entry={entry}>
  <Content />
</ServicePageLayout>
