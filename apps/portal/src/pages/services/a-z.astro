---
import { getCollection, type CollectionEntry } from 'astro:content';
import BoilerplatePageLayout from '../../layouts/BoilerplatePageLayout.astro';

const services = (await getCollection('services')).sort(
  (a: CollectionEntry<'services'>, b: CollectionEntry<'services'>) =>
    a.data.title.localeCompare(b.data.title),
);

// Group by starting letter.
type Group = { letter: string; items: CollectionEntry<'services'>[] };
const groups: Group[] = [];
for (const s of services) {
  const letter = s.data.title[0].toUpperCase();
  const bucket = groups.find((g) => g.letter === letter);
  if (bucket) bucket.items.push(s);
  else groups.push({ letter, items: [s] });
}

const lifeStageLabel: Record<string, string> = {
  live: 'Live',
  work: 'Work',
  business: 'Do business',
  visit: 'Visit',
};
---

<BoilerplatePageLayout
  title="A–Z services"
  description="Every government service on gov.gh in alphabetical order."
  lede={`All ${services.length} services listed alphabetically. Jump to a letter or browse the full list.`}
>
  <nav aria-label="Jump to letter" class="jump">
    {
      groups.map((g) => (
        <a href={`#letter-${g.letter}`} class="jump__link">
          {g.letter}
        </a>
      ))
    }
  </nav>

  <section class="list">
    {
      groups.map((g) => (
        <div class="list__group">
          <h2 id={`letter-${g.letter}`} class="list__letter">
            {g.letter}
          </h2>
          <ul>
            {g.items.map((s) => (
              <li>
                <a href={`/services/${s.slug}/`} class="list__item">
                  <span class="list__title">{s.data.title}</span>
                  <span class={`list__chip list__chip--${s.data.lifeStage}`}>
                    {lifeStageLabel[s.data.lifeStage]}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </section>
</BoilerplatePageLayout>

<style>
  .jump {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin: 1.5rem 0 2rem;
    padding: 0.75rem;
    background: #fff;
    border: 1px solid #e5e0d6;
    border-radius: 3px;
  }
  .jump__link {
    min-width: 32px;
    text-align: center;
    padding: 0.375rem 0.5rem;
    text-decoration: none;
    color: #004527;
    font-weight: 600;
    border: 1px solid transparent;
    border-radius: 2px;
  }
  .jump__link:hover,
  .jump__link:focus-visible {
    border-color: #e5e0d6;
    background: #faf7f2;
  }
  .jump__link:focus-visible {
    outline: 3px solid #fcd116;
    outline-offset: 2px;
  }

  .list__group {
    margin-bottom: 1.5rem;
  }
  .list__letter {
    font-family: Georgia, serif;
    font-size: 1.5rem;
    color: #004527;
    margin: 1rem 0 0.5rem;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid #e5e0d6;
  }
  .list ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .list__item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.75rem;
    text-decoration: none;
    color: #2b2e34;
    border-bottom: 1px solid #faf7f2;
    min-height: 44px;
  }
  .list__item:hover,
  .list__item:focus-visible {
    background: #fff;
  }
  .list__item:focus-visible {
    outline: 3px solid #fcd116;
    outline-offset: -3px;
  }
  .list__title {
    flex: 1;
  }
  .list__chip {
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
    padding: 2px 7px;
    border-radius: 2px;
    white-space: nowrap;
    background: #faf7f2;
    color: #2b2e34;
    border: 1px solid #e5e0d6;
  }
  .list__chip--live {
    border-left: 3px solid #005a35;
  }
  .list__chip--work {
    border-left: 3px solid #820b18;
  }
  .list__chip--business {
    border-left: 3px solid #e0b912;
  }
  .list__chip--visit {
    border-left: 3px solid #000;
  }
</style>
