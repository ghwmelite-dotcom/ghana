---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout lang="tw" title="Te ase" description="Dwumadie a wo hwehwɛ sɛ wo te ase wɔ Ghana.">
  <div class="tw">
    <p class="eyebrow">· Te ase ·</p>
    <h1>Dwumadie a wo hwehwɛ sɛ wo te ase</h1>
    <p class="lede">
      Ghana Card, awoɔ krataa, aware, adwofie ne mmusua ho nsɛm. Dwumadie pɔtee no, hwɛ Engiresi
      kasa mu.
    </p>
    <p class="fallback">
      <strong>Twi nsɛm pii yɛ v1.1 ho.</strong> Sɛ wo hwehwɛ dwumadie nyinaa nsɛm a, kɔ <a
        href="/services/live/">English version</a
      >.
    </p>
  </div>
</BaseLayout>

<style>
  .tw {
    max-width: 40rem;
    margin: 0 auto;
    padding: 1.5rem 1.25rem 4rem;
  }
  .eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    color: #820b18;
    text-transform: uppercase;
    margin: 0 0 0.75rem;
  }
  h1 {
    font-family: Georgia, serif;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.1;
    color: #004527;
    margin: 0 0 0.75rem;
  }
  .lede {
    font-size: 1.125rem;
    color: #3e424a;
    margin: 0 0 1.5rem;
  }
  .fallback {
    padding: 0.875rem 1rem;
    background: #fff8e1;
    border-left: 3px solid #fcd116;
    border-radius: 3px;
    font-size: 0.875rem;
    color: #3e424a;
  }
  .fallback a {
    color: #004527;
    text-decoration: underline;
  }
</style>
