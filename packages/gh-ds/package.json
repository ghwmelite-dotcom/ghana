    "typecheck": "tsc --noEmit",
    "lint": "eslint --ext .ts,.mjs src scripts",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "node --experimental-strip-types scripts/build-css.mjs",
    "fonts": "node scripts/fetch-fonts.mjs",
