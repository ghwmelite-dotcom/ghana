---
/**
 * <Card> — Ghana Design System Tier-2 content component.
 *
 * A bordered container with a heading and a body slot. When `href` is set,
 * the whole card is a link — the "entire card clickable" pattern borrowed
 * from GOV.UK Frontend's content cards. Progressive-enhancement safe: the
 * whole card is a single `<a>` in link mode, so no JavaScript is needed to
 * make the larger hit area work.
 *
 * The heading is rendered at a configurable level (`h2` default). Pick the
 * level that matches the heading hierarchy of the surrounding page —
 * breaking h1 → h3 is a WCAG failure.
 *
 * Usage — static content card:
 *   <Card title="Renew your passport">
 *     <p>Renew your Ghanaian passport in four steps.</p>
 *   </Card>
 *
 * Usage — entire-card-clickable:
 *   <Card
 *     title="Apply for the Ghana Card"
 *     href="/services/ghana-card/"
 *     description="Register if you are 15 or over and have not registered yet."
 *   />
 */

type HeadingLevel = 'h2' | 'h3' | 'h4';

interface Props {
  title: string;
  /** Optional single-line description. Shown below the title. */
  description?: string;
  /** Whole-card link. Uses the title's text as the accessible name. */
  href?: string;
  /**
   * HTML heading level. Match the surrounding page hierarchy.
   * Default: `h2`.
   */
  headingLevel?: HeadingLevel;
  class?: string;
}

const { title, description, href, headingLevel = 'h2', class: extraClass } = Astro.props;

const Heading = headingLevel;

const classes = ['gh-card', href ? 'gh-card--linked' : null, extraClass].filter(Boolean).join(' ');
---

<article class={classes}>
  <Heading class="gh-card__title">
    {
      href ? (
        <a href={href} class="gh-card__link">
          {title}
        </a>
      ) : (
        title
      )
    }
  </Heading>

  {description && <p class="gh-card__description">{description}</p>}

  <slot />
</article>

<style>
  .gh-card {
    padding: var(--space-6);
    background: var(--color-surface-raised);
    border: var(--border-width-hairline) solid var(--color-border-default);
    border-top: 4px solid var(--color-action-primary);
    border-radius: var(--radius-md);
  }

  .gh-card + .gh-card {
    margin-top: var(--space-4);
  }

  .gh-card__title {
    font-family: var(--font-display);
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-heading);
    margin: 0 0 var(--space-2) 0;
  }

  .gh-card__link {
    color: var(--color-link);
    text-decoration: underline;
    text-underline-offset: 0.15em;
    text-decoration-thickness: 0.06em;
  }

  .gh-card__link:hover {
    text-decoration-thickness: 0.12em;
  }

  /* Entire-card-clickable: the link's pseudo-element expands to cover the
     whole card so any click within card bounds follows the link. Text
     selection inside the card still works because the pseudo-element is
     zero-area for selection purposes. */
  .gh-card--linked {
    position: relative;
  }

  .gh-card--linked .gh-card__link::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
  }

  .gh-card--linked:hover {
    background: var(--ghana-green-50);
  }

  .gh-card--linked:has(.gh-card__link:focus-visible) {
    outline: var(--border-width-focus) solid var(--color-focus-ring);
    outline-offset: 2px;
  }

  .gh-card__description {
    color: var(--color-text-secondary);
    font-size: var(--font-size-base);
    line-height: var(--line-height-body);
    margin: 0;
  }

  .gh-card > *:last-child {
    margin-bottom: 0;
  }
</style>
