---
/**
 * <CookieBanner> — Ghana Design System Tier-3 component.
 *
 * Top-of-page cookie-consent disclosure per `.claude/CLAUDE.md §9`'s
 * DPA-2012 posture and GOV.UK Frontend's `govuk-cookie-banner` pattern.
 *
 * v0 shipping posture (no backend yet):
 *   - Renders the banner markup with a `<form>` that POSTs to endpoints
 *     under `{acceptAction}` / `{rejectAction}` (default `/cookies/accept`
 *     and `/cookies/reject`).
 *   - Those endpoints do not yet exist — they will be implemented as
 *     Cloudflare Pages Functions / Workers in Week 7 and set a cookie
 *     then 303-redirect back. Until then, submitting either button is a
 *     404 — the banner's disclosure purpose is fulfilled by visibility.
 *   - A small inline JS enhancement is a future PR: it will
 *     set the cookie directly via `document.cookie` and hide the banner
 *     without a round-trip. Non-JS path remains the canonical fallback.
 *
 * Structure (WCAG 1.3.1):
 *   - `role="region"` + `aria-labelledby`, so SR users can skip past it
 *     or land on it via rotor.
 *   - Heading + description + three actions (Accept / Reject / View).
 *   - "View cookies" is an anchor to the detailed policy page; the two
 *     submit buttons are inside a single `<form>` with distinct
 *     `formaction` values so one form carries both choices.
 *
 * Usage:
 *   <CookieBanner />
 *   <CookieBanner
 *     title="Cookies on ohcs.gov.gh"
 *     acceptAction="/cookies/accept?return=/about"
 *     rejectAction="/cookies/reject?return=/about"
 *     policyHref="/cookies"
 *   >
 *     <p>
 *       We use cookies to make gov.gh work. We would like to use extra
 *       cookies to measure how you use it and improve the service.
 *     </p>
 *   </CookieBanner>
 */

interface Props {
  /** Banner heading. Defaults to "Cookies on gov.gh". */
  title?: string;
  /** Endpoint that accepts non-essential cookies. */
  acceptAction?: string;
  /** Endpoint that rejects non-essential cookies. */
  rejectAction?: string;
  acceptLabel?: string;
  rejectLabel?: string;
  /** Detailed cookie-policy page. */
  policyHref?: string;
  policyLabel?: string;
  id?: string;
  class?: string;
}

const {
  title = 'Cookies on gov.gh',
  acceptAction = '/cookies/accept',
  rejectAction = '/cookies/reject',
  acceptLabel = 'Accept cookies',
  rejectLabel = 'Reject cookies',
  policyHref = '/cookies',
  policyLabel = 'View cookies',
  id = 'cookie-banner',
  class: extraClass,
} = Astro.props;

const classes = ['gh-cookie-banner', extraClass].filter(Boolean).join(' ');
---

<aside class={classes} role="region" aria-labelledby={`${id}-title`} id={id}>
  <div class="gh-cookie-banner__inner">
    <h2 id={`${id}-title`} class="gh-cookie-banner__title">{title}</h2>
    <div class="gh-cookie-banner__body">
      <slot>
        <p>
          We use cookies to make gov.gh work. We would like to use extra cookies to understand how
          you use the service so we can improve it.
        </p>
      </slot>
    </div>
    <form class="gh-cookie-banner__actions" method="post" action={acceptAction}>
      <button
        class="gh-cookie-banner__button gh-cookie-banner__button--primary"
        type="submit"
        formaction={acceptAction}
      >
        {acceptLabel}
      </button>
      <button
        class="gh-cookie-banner__button gh-cookie-banner__button--primary"
        type="submit"
        formaction={rejectAction}
      >
        {rejectLabel}
      </button>
      <a class="gh-cookie-banner__link" href={policyHref}>
        {policyLabel}
      </a>
    </form>
  </div>
</aside>

<style>
  .gh-cookie-banner {
    background: var(--ghana-ink-50);
    border-bottom: var(--border-width-default) solid var(--color-border-default);
    color: var(--color-text-default);
  }

  .gh-cookie-banner__inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: var(--space-5) var(--space-4);
  }

  .gh-cookie-banner__title {
    font-family: var(--font-display);
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-heading);
    margin: 0 0 var(--space-3) 0;
  }

  .gh-cookie-banner__body {
    font-size: var(--font-size-base);
    line-height: var(--line-height-body);
    margin-bottom: var(--space-4);
    max-width: 56rem;
  }

  .gh-cookie-banner__body > :first-child {
    margin-top: 0;
  }

  .gh-cookie-banner__body > :last-child {
    margin-bottom: 0;
  }

  .gh-cookie-banner__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
  }

  .gh-cookie-banner__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: var(--space-2) var(--space-5);
    font: inherit;
    font-weight: var(--font-weight-bold);
    color: #ffffff;
    background: var(--color-action-primary);
    border: var(--border-width-default) solid var(--color-action-primary);
    border-radius: var(--radius-md);
    cursor: pointer;
    -webkit-appearance: none;
    appearance: none;
  }

  .gh-cookie-banner__button:hover {
    background: var(--color-action-primary-hover);
    border-color: var(--color-action-primary-hover);
  }

  .gh-cookie-banner__button:focus-visible {
    outline: var(--border-width-focus) solid var(--color-focus-ring);
    outline-offset: 2px;
    box-shadow: inset 0 0 0 1px var(--color-text-default);
  }

  .gh-cookie-banner__link {
    color: var(--color-link);
    text-decoration: underline;
    text-underline-offset: 0.15em;
    text-decoration-thickness: 0.06em;
    padding: var(--space-2) 0;
    min-height: 2.75rem;
    display: inline-flex;
    align-items: center;
  }

  .gh-cookie-banner__link:hover {
    text-decoration-thickness: 0.12em;
  }

  .gh-cookie-banner__link:focus-visible {
    outline: var(--border-width-focus) solid var(--color-focus-ring);
    outline-offset: 2px;
    background: var(--color-focus-ring);
    color: var(--color-text-default);
    text-decoration: none;
  }
</style>
