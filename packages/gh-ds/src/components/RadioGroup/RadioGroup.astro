---
/**
 * <RadioGroup> — Ghana Design System Tier-1 foundation component.
 *
 * Renders a fieldset of mutually-exclusive choices. Ported in intent from
 * GOV.UK Frontend's `govuk-radios`, per ADR-003.
 *
 * Structure (WCAG 1.3.1, 3.3.2, 2.5.5):
 *   - `<fieldset>` wraps every group so assistive tech announces "group".
 *   - `<legend>` is always visible — it is the group name.
 *   - Group-level hint precedes the options; group-level error follows the
 *     legend. Both are wired via `aria-describedby` on the fieldset.
 *   - Each option is `<input type="radio">` + `<label>` + optional per-option
 *     hint. The label is clickable and sized to a 44 px touch target. The
 *     native input is visually hidden (not display-none — still focusable
 *     and in the a11y tree) and a CSS pseudo-element draws the circle.
 *   - `orientation="inline"` lays out options horizontally for binary Yes/No
 *     choices. Vertical is the default for all multi-option groups.
 *
 * Progressive enhancement (§1):
 *   Works without JavaScript — native radio inputs, native fieldset grouping,
 *   native form submission.
 *
 * Usage:
 *   <RadioGroup
 *     name="has-ghana-card"
 *     legend="Do you have a Ghana Card?"
 *     orientation="inline"
 *     required
 *     options={[
 *       { value: 'yes', label: 'Yes' },
 *       { value: 'no', label: 'No' },
 *     ]}
 *   />
 *
 *   <RadioGroup
 *     name="language"
 *     legend="Which language do you use most often?"
 *     hint="We use this to show you service pages in the right language."
 *     value="en"
 *     options={[
 *       { value: 'en', label: 'English' },
 *       { value: 'tw', label: 'Twi' },
 *       { value: 'ew', label: 'Ewe' },
 *       { value: 'gaa', label: 'Ga' },
 *       { value: 'dag', label: 'Dagbani' },
 *       { value: 'ha', label: 'Hausa' },
 *     ]}
 *   />
 */

interface RadioOption {
  value: string;
  label: string;
  hint?: string;
  disabled?: boolean;
}

interface Props {
  name: string;
  legend: string;
  options: ReadonlyArray<RadioOption>;
  /** Group-level hint rendered before options. */
  hint?: string;
  /**
   * When truthy, the fieldset enters error mode. Renders a role="alert"
   * message after the legend and wires it via aria-describedby.
   */
  error?: string;
  /** ID prefix for options. Defaults to `name`. */
  id?: string;
  /** Currently selected value. */
  value?: string;
  orientation?: 'vertical' | 'inline';
  required?: boolean;
  class?: string;
}

const {
  name,
  legend,
  options,
  hint,
  error,
  id: idProp,
  value,
  orientation = 'vertical',
  required = false,
  class: extraClass,
} = Astro.props;

const id = idProp ?? name;
const hintId = hint ? `${id}-hint` : undefined;
const errorId = error ? `${id}-error` : undefined;
const describedBy = [hintId, errorId].filter(Boolean).join(' ') || undefined;

const groupClass = ['gh-form-group', error ? 'gh-form-group--error' : null, extraClass]
  .filter(Boolean)
  .join(' ');

const radiosClass = ['gh-radios', orientation === 'inline' ? 'gh-radios--inline' : null]
  .filter(Boolean)
  .join(' ');
---

<div class={groupClass}>
  <fieldset class="gh-fieldset" aria-describedby={describedBy}>
    <legend class="gh-fieldset__legend">
      <span class="gh-fieldset__legend-text">
        {legend}
        {
          required && (
            <span class="gh-label__required" aria-hidden="true">
              *
            </span>
          )
        }
      </span>
    </legend>

    {
      hint && (
        <p id={hintId} class="gh-hint">
          {hint}
        </p>
      )
    }

    {
      error && (
        <p id={errorId} class="gh-error-message" role="alert">
          <span class="gh-error-message__prefix">Error:</span> {error}
        </p>
      )
    }

    <div class={radiosClass}>
      {
        options.map((option, i) => {
          const optionId = `${id}-${i}`;
          const optionHintId = option.hint ? `${optionId}-hint` : undefined;
          const isChecked = value === option.value;
          return (
            <div class="gh-radios__item">
              <input
                class="gh-radios__input"
                type="radio"
                id={optionId}
                name={name}
                value={option.value}
                checked={isChecked}
                disabled={option.disabled}
                required={required && i === 0}
                aria-describedby={optionHintId}
              />
              <label class="gh-radios__label" for={optionId}>
                {option.label}
              </label>
              {option.hint && (
                <div id={optionHintId} class="gh-radios__hint">
                  {option.hint}
                </div>
              )}
            </div>
          );
        })
      }
    </div>
  </fieldset>
</div>

<style>
  .gh-form-group {
    display: block;
    margin-bottom: var(--space-6);
  }

  .gh-form-group--error {
    padding-left: var(--space-4);
    border-left: 5px solid var(--color-error);
  }

  /* ─── Fieldset + legend ───────────────────────────────── */
  .gh-fieldset {
    border: 0;
    padding: 0;
    margin: 0;
    min-width: 0;
  }

  .gh-fieldset__legend {
    /* Native legend rendering is inconsistent; we use a span inside to
       control spacing and font while keeping the native legend for
       accessibility. */
    padding: 0;
    display: table;
  }

  .gh-fieldset__legend-text {
    display: block;
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-lg);
    line-height: var(--line-height-heading);
    color: var(--color-text-default);
    margin-bottom: var(--space-3);
  }

  .gh-label__required {
    color: var(--color-error);
    margin-left: 0.2em;
  }

  .gh-hint {
    font-size: var(--font-size-base);
    line-height: var(--line-height-body);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-3);
  }

  .gh-error-message {
    color: var(--color-error);
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-base);
    line-height: var(--line-height-body);
    margin-bottom: var(--space-3);
  }

  .gh-error-message__prefix {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ─── Radios layout ───────────────────────────────────── */
  .gh-radios {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .gh-radios--inline {
    flex-direction: row;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-6);
  }

  .gh-radios__item {
    position: relative;
    display: block;
    min-height: 2.75rem; /* 44 px — WCAG 2.5.5 */
  }

  /* Hide the native input visually but keep it in the a11y tree and
     hit-testable through the adjacent label. */
  .gh-radios__input {
    position: absolute;
    z-index: 1;
    top: 0;
    left: 0;
    width: 2.75rem;
    height: 2.75rem;
    margin: 0;
    opacity: 0;
    cursor: pointer;
  }

  .gh-radios__input:disabled {
    cursor: not-allowed;
  }

  /* The label renders the whole clickable row, with a pseudo-element
     circle for the visual indicator. */
  .gh-radios__label {
    display: inline-block;
    padding: var(--space-2) 0 var(--space-2) 3.25rem;
    min-height: 2.75rem;
    line-height: var(--line-height-body);
    cursor: pointer;
    touch-action: manipulation;
  }

  .gh-radios__label::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 2.75rem;
    height: 2.75rem;
    border: var(--border-width-default) solid var(--color-text-default);
    border-radius: 50%;
    background: var(--color-surface-raised);
  }

  .gh-radios__label::after {
    content: '';
    position: absolute;
    top: 0.6875rem; /* (2.75rem - 1.375rem) / 2 */
    left: 0.6875rem;
    width: 1.375rem;
    height: 1.375rem;
    border-radius: 50%;
    background: var(--color-text-default);
    opacity: 0;
  }

  .gh-radios__input:checked + .gh-radios__label::after {
    opacity: 1;
  }

  .gh-radios__input:focus-visible + .gh-radios__label::before {
    outline: var(--border-width-focus) solid var(--color-focus-ring);
    outline-offset: 0;
    box-shadow: inset 0 0 0 2px var(--color-text-default);
  }

  .gh-radios__input:disabled + .gh-radios__label,
  .gh-radios__input:disabled ~ .gh-radios__hint {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .gh-radios__hint {
    display: block;
    padding-left: 3.25rem;
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: var(--line-height-body);
  }

  /* Error-state border tint on the circle. */
  .gh-form-group--error .gh-radios__label::before {
    border-color: var(--color-error);
    border-width: var(--border-width-default);
  }
</style>
