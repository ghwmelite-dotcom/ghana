---
/**
 * <Search> — Ghana Design System Tier-3 component.
 *
 * The "I am looking for…" form that lets a citizen jump straight to any
 * service by name. Extracted from the inline markup that shipped in PR 3
 * on `apps/portal/src/pages/index.astro`. Ported in intent from GOV.UK's
 * search-with-button pattern.
 *
 * Accessibility & semantics:
 *   - Wrapped in `<form role="search">` so screen-reader rotor lists it
 *     as "search, form".
 *   - The label is visible, never a placeholder (§1 + WCAG 3.3.2).
 *   - Native `<input type="search">` triggers the browser's built-in
 *     clear-button and search-keyboard on mobile.
 *   - `enterkeyhint="search"` tells on-screen keyboards to show the
 *     search glyph.
 *   - Uses `method="get"` by default: queries are shareable URLs and
 *     results pages can be bookmarked.
 *
 * Progressive enhancement: pure HTML form. Works with JavaScript disabled.
 * A future enhancement will add an autocomplete island for Tier-2/3.
 *
 * Usage:
 *   <Search
 *     label="I am looking for…"
 *     action="/search"
 *     placeholder="Passport, Ghana Card, tax…"
 *   />
 *
 *   Sticky on results pages:
 *   <Search label="I am looking for…" action="/search" value={q} />
 */

interface Props {
  label: string;
  /** Where the form submits. Defaults to `/search`. */
  action?: string;
  method?: 'get' | 'post';
  /** Input `name` attribute. Defaults to `q`. */
  name?: string;
  /** DOM id. Defaults to the `name` value. */
  id?: string;
  /** Short placeholder hint (never the sole label). */
  placeholder?: string;
  /** Prefilled query — used on results pages for sticky search. */
  value?: string;
  /** Submit button text. Defaults to "Find". */
  buttonLabel?: string;
  class?: string;
}

const {
  label,
  action = '/search',
  method = 'get',
  name = 'q',
  id: idProp,
  placeholder,
  value,
  buttonLabel = 'Find',
  class: extraClass,
} = Astro.props;

const id = idProp ?? name;
const classes = ['gh-search', extraClass].filter(Boolean).join(' ');
---

<form class={classes} role="search" action={action} method={method}>
  <label for={id} class="gh-search__label">{label}</label>
  <div class="gh-search__row">
    <input
      id={id}
      name={name}
      type="search"
      autocomplete="off"
      spellcheck="false"
      enterkeyhint="search"
      placeholder={placeholder}
      value={value}
      required
      class="gh-search__input"
    />
    <button type="submit" class="gh-search__button">
      <svg
        class="gh-search__icon"
        width="20"
        height="20"
        viewBox="0 0 20 20"
        aria-hidden="true"
        focusable="false"
      >
        <path
          d="M19 19l-5.2-5.2m1.7-4.8a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0Z"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
      <span>{buttonLabel}</span>
    </button>
  </div>
</form>

<style>
  .gh-search {
    display: block;
    max-width: 42rem;
  }

  .gh-search__label {
    display: block;
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-base);
    line-height: var(--line-height-heading);
    color: var(--color-text-default);
    margin-bottom: var(--space-2);
  }

  .gh-search__row {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .gh-search__input {
    flex: 1 1 22rem;
    min-width: 0;
    min-height: 2.75rem;
    padding: var(--space-2) var(--space-3);
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    line-height: var(--line-height-body);
    color: var(--color-text-default);
    background: var(--color-surface-raised);
    border: var(--border-width-default) solid var(--color-text-default);
    border-radius: var(--radius-md);
    -webkit-appearance: none;
    appearance: none;
  }

  .gh-search__input:focus-visible {
    outline: var(--border-width-focus) solid var(--color-focus-ring);
    outline-offset: 0;
    box-shadow: inset 0 0 0 2px var(--color-text-default);
  }

  .gh-search__input::placeholder {
    color: var(--color-text-muted);
    opacity: 1;
  }

  .gh-search__button {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    min-height: 2.75rem;
    padding: var(--space-2) var(--space-5);
    font: inherit;
    font-weight: var(--font-weight-bold);
    background: var(--color-action-primary);
    color: #ffffff;
    border: var(--border-width-default) solid var(--color-action-primary);
    border-radius: var(--radius-md);
    cursor: pointer;
    -webkit-appearance: none;
    appearance: none;
  }

  .gh-search__button:hover {
    background: var(--color-action-primary-hover);
    border-color: var(--color-action-primary-hover);
  }

  .gh-search__button:focus-visible {
    outline: var(--border-width-focus) solid var(--color-focus-ring);
    outline-offset: 2px;
    box-shadow: inset 0 0 0 1px var(--color-text-default);
  }

  .gh-search__icon {
    flex-shrink: 0;
  }
</style>
