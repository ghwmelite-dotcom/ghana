---
/**
 * <SummaryList> — Ghana Design System Tier-3 service-flow component.
 *
 * The GOV.UK "check your answers" pattern. Displayed just before the
 * final submit on any multi-step service flow so the user can review
 * what they entered. Ported in intent from `govuk-summary-list`, per
 * ADR-003.
 *
 * Structure (WCAG 1.3.1):
 *   - Semantically a `<dl>`: each row is one question (`<dt>`) and the
 *     user's answer (`<dd>`).
 *   - Optional "Change" action per row — rendered as a third `<dd>` so
 *     SR users hear the answer then the change link in natural order.
 *   - The change link's accessible name includes the question context
 *     ("Change full name"), not just "Change", via a visually-hidden
 *     suffix.
 *
 * Usage:
 *   <SummaryList
 *     rows={[
 *       {
 *         key: 'Full name',
 *         value: 'Ama Asante',
 *         action: { href: '/apply/identity#name', label: 'Change', hiddenText: 'full name' },
 *       },
 *       {
 *         key: 'Date of birth',
 *         value: '27 March 1985',
 *         action: { href: '/apply/identity#dob', label: 'Change', hiddenText: 'date of birth' },
 *       },
 *       {
 *         key: 'Ghana Card number',
 *         value: 'GHA-123456789-0',
 *       },
 *     ]}
 *   />
 */

interface SummaryAction {
  href: string;
  /** Visible text. Usually "Change". */
  label: string;
  /** Appended visually-hidden to the link for SR context, e.g. "full name". */
  hiddenText?: string;
}

interface SummaryRow {
  key: string;
  value: string;
  action?: SummaryAction;
}

interface Props {
  rows: ReadonlyArray<SummaryRow>;
  class?: string;
}

const { rows, class: extraClass } = Astro.props;
const classes = ['gh-summary-list', extraClass].filter(Boolean).join(' ');
---

<dl class={classes}>
  {
    rows.map((row) => (
      <div class="gh-summary-list__row">
        <dt class="gh-summary-list__key">{row.key}</dt>
        <dd class="gh-summary-list__value">{row.value}</dd>
        {row.action && (
          <dd class="gh-summary-list__action">
            <a href={row.action.href}>
              {row.action.label}
              {row.action.hiddenText && (
                <span class="gh-visually-hidden"> {row.action.hiddenText}</span>
              )}
            </a>
          </dd>
        )}
      </div>
    ))
  }
</dl>

<style>
  .gh-summary-list {
    margin: var(--space-4) 0 var(--space-8);
    font-size: var(--font-size-base);
    line-height: var(--line-height-body);
  }

  .gh-summary-list__row {
    display: grid;
    grid-template-columns: 1fr 2fr auto;
    gap: var(--space-3) var(--space-5);
    padding: var(--space-3) 0;
    border-bottom: var(--border-width-hairline) solid var(--color-border-default);
  }

  .gh-summary-list__row:first-child {
    border-top: var(--border-width-hairline) solid var(--color-border-default);
  }

  .gh-summary-list__key {
    font-weight: var(--font-weight-semibold);
    margin: 0;
  }

  .gh-summary-list__value {
    margin: 0;
    color: var(--color-text-default);
  }

  .gh-summary-list__action {
    margin: 0;
    text-align: right;
  }

  .gh-summary-list__action a {
    color: var(--color-link);
    text-decoration: underline;
    text-underline-offset: 0.15em;
    text-decoration-thickness: 0.06em;
    font-weight: var(--font-weight-semibold);
  }

  .gh-summary-list__action a:hover {
    text-decoration-thickness: 0.12em;
  }

  .gh-summary-list__action a:focus-visible {
    outline: var(--border-width-focus) solid var(--color-focus-ring);
    outline-offset: 2px;
    background: var(--color-focus-ring);
    color: var(--color-text-default);
    text-decoration: none;
  }

  .gh-visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 40rem) {
    /* On narrow viewports, stack the row: key above value, action right-
       aligned on its own line. */
    .gh-summary-list__row {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      gap: var(--space-1) var(--space-3);
    }

    .gh-summary-list__key {
      grid-column: 1 / -1;
    }

    .gh-summary-list__value {
      grid-column: 1;
    }

    .gh-summary-list__action {
      grid-column: 2;
      align-self: start;
    }
  }
</style>
